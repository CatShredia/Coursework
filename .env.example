# Public URL выданный Tuna-туннелем (используется в CORS/JWT/email-ссылках)
# пример: https://runews-abc.tuna.am
# ВАЖНО: без завершающего /
PUBLIC_URL=https://your-tuna-domain

POSTGRES_DB=news_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

JWT_KEY=CHANGE_ME_TO_A_SECURE_32_PLUS_CHAR_SECRET

# SMTP: одинаковые имена переменных. Раскомментируйте ОДИН блок и подставьте свои значения.
# Для production также подойдут Brevo/SendGrid/Mailgun (обычно порт 587, SMTP_USE_SSL=true).
#
# --- Yandex ---
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_FROM=your-login@yandex.ru
# SMTP_USERNAME=your-login@yandex.ru
# SMTP_PASSWORD=your-yandex-app-password
# SMTP_USE_SSL=true
# SMTP_PREFER_IPV4=false
#
# --- Gmail ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM=your-login@gmail.com
# SMTP_USERNAME=your-login@gmail.com
# SMTP_PASSWORD=your-gmail-app-password
# SMTP_USE_SSL=true
# SMTP_PREFER_IPV4=false
#
# --- Mailpit (локальный SMTP в docker-compose; UI: http://localhost:8025) ---
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_FROM=noreply@runews.local
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_SSL=false
# SMTP_PREFER_IPV4=false

# --- Bravo ---
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_FROM=noreply@your-domain.com
# SMTP_USERNAME=your-brevo-smtp-login
# SMTP_PASSWORD=your-brevo-smtp-key
# SMTP_USE_SSL=true
# SMTP_PREFER_IPV4=false

GIGACHAT_CLIENT_ID=your-gigachat-client-id
GIGACHAT_CLIENT_SECRET=your-gigachat-client-secret

