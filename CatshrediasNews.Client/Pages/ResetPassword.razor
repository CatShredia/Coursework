@page "/reset-password"
@using System.Net.Http.Json
@layout AuthLayout
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Новый пароль — Runews</PageTitle>

<div class="auth-card">
    <div class="auth-logo"><span>Runews</span></div>
    <h1 class="auth-title">Новый пароль</h1>

    @if (_invalidLink)
    {
        <div class="auth-error">
            <i class="bi bi-x-circle"></i> Ссылка недействительна или устарела.
        </div>
        <div class="auth-links" style="margin-top:16px">
            <a href="/forgot-password">Запросить новую ссылку</a>
        </div>
    }
    else if (_done)
    {
        <div class="auth-success">
            <i class="bi bi-check-circle"></i> Пароль успешно изменён. Теперь можете войти.
        </div>
        <a href="/login" class="auth-btn" style="margin-top:8px;text-decoration:none;display:flex;justify-content:center">
            Войти
        </a>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="auth-error"><i class="bi bi-exclamation-circle"></i> @_error</div>
        }

        <div class="auth-field">
            <label>Новый пароль</label>
            <div class="input-wrap @(_passwordInvalid ? "input-invalid" : "")">
                <i class="bi bi-lock"></i>
                <input type="@(_showPassword ? "text" : "password")"
                       placeholder="Минимум 6 символов"
                       @bind="_password" @bind:event="oninput"
                       @onblur="ValidatePassword" />
                <button class="input-eye" type="button" @onclick="() => _showPassword = !_showPassword">
                    <i class="bi @(_showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                </button>
            </div>
            @if (_passwordInvalid)
            {
                <span class="field-error">Пароль должен содержать минимум 6 символов</span>
            }
        </div>

        <div class="auth-field">
            <label>Повторите пароль</label>
            <div class="input-wrap @(_confirmInvalid ? "input-invalid" : "")">
                <i class="bi bi-lock-fill"></i>
                <input type="@(_showPassword ? "text" : "password")"
                       placeholder="Повторите пароль"
                       @bind="_confirm" @bind:event="oninput"
                       @onblur="ValidateConfirm" />
            </div>
            @if (_confirmInvalid)
            {
                <span class="field-error">Пароли не совпадают</span>
            }
        </div>

        <button class="auth-btn" @onclick="Submit" disabled="@_loading">
            @if (_loading) { <span class="auth-spinner"></span> }
            else { <span>Сохранить пароль</span> }
        </button>
    }
</div>

@code {
    private string _password = "", _confirm = "";
    private string? _error, _token;
    private bool _loading, _done, _invalidLink, _showPassword, _passwordInvalid, _confirmInvalid;

    protected override void OnInitialized()
    {
        var uri   = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _token = query["token"];
        if (string.IsNullOrEmpty(_token)) _invalidLink = true;
    }

    private void ValidatePassword() => _passwordInvalid = !string.IsNullOrWhiteSpace(_password) && _password.Length < 6;
    private void ValidateConfirm()  => _confirmInvalid  = !string.IsNullOrWhiteSpace(_confirm) && _confirm != _password;

    private async Task Submit()
    {
        ValidatePassword();
        ValidateConfirm();
        if (string.IsNullOrWhiteSpace(_password) || string.IsNullOrWhiteSpace(_confirm))
        { _error = "Заполните все поля."; return; }
        if (_passwordInvalid || _confirmInvalid) return;

        _loading = true; _error = null;
        var response = await Http.PostAsJsonAsync("api/auth/reset-password", new { token = _token, newPassword = _password });
        _loading = false;

        if (response.IsSuccessStatusCode) _done = true;
        else _invalidLink = true;
    }
}
