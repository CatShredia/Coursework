@page "/articles/{Id:int}"
@inject ArticleService ArticleSvc
@inject ModerationService ModerationSvc
@inject AuthService Auth
@inject NavigationManager Nav
@inject ArticleHeadingsService HeadingsSvc
@inject CommentService CommentSvc
@implements IDisposable

<PageTitle>@(_article?.Title ?? "Статья") — Runews</PageTitle>

@if (_loading)
{
    <div class="article-view-skeleton">
        <div class="skeleton" style="height:32px;width:60%;margin-bottom:16px"></div>
        <div class="skeleton" style="height:14px;width:30%;margin-bottom:24px"></div>
        <div class="skeleton" style="height:14px;width:100%;margin-bottom:8px"></div>
        <div class="skeleton" style="height:14px;width:95%;margin-bottom:8px"></div>
        <div class="skeleton" style="height:14px;width:88%;margin-bottom:8px"></div>
        <div class="skeleton" style="height:14px;width:92%;margin-bottom:8px"></div>
        <div class="skeleton" style="height:14px;width:70%"></div>
    </div>
}
else if (_article is null)
{
    <div class="feed-empty">
        <i class="bi bi-file-earmark-x"></i>
        <p>Статья не найдена или была удалена.</p>
        <a href="/" style="color:var(--accent);margin-top:8px;display:inline-block">← Вернуться в ленту</a>
    </div>
}
else
{
    <div class="article-view">

        <!-- Кнопка назад -->
        <button class="article-back" @onclick="() => Nav.NavigateTo(Nav.BaseUri)">
            <i class="bi bi-arrow-left"></i> Назад
        </button>

        <!-- Заголовок -->
        <h1 class="article-view-title">@_article.Title</h1>

        <!-- Мета -->
        <div class="article-view-meta">
            <span><i class="bi bi-calendar3"></i> @_article.PublishedAt.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("ru-RU"))</span>
            @if (!string.IsNullOrEmpty(_article.RssAuthor))
            {
                <span><i class="bi bi-person"></i> @_article.RssAuthor</span>
            }
            else if (_article.AuthorId is not null && !string.IsNullOrEmpty(_article.Author))
            {
                <a href="/profile/@_article.AuthorId" class="article-view-author">
                    <i class="bi bi-person-circle"></i> @_article.Author
                </a>
            }
            <span><i class="bi bi-heart"></i> @_article.LikesCount</span>
            @if (!string.IsNullOrEmpty(_article.SourceUrl))
            {
                <a href="@_article.SourceUrl" target="_blank" class="article-view-source">
                    <i class="bi bi-box-arrow-up-right"></i> @GetDomain(_article.SourceUrl)
                </a>
            }
        </div>

        <!-- Теги -->
        @if (_article.Tags.Any())
        {
            <div class="article-tags" style="margin-bottom:24px">
                @foreach (var tag in _article.Tags)
                {
                    <span class="article-tag">@tag</span>
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_article.ImageUrl))
        {
            <img class="article-view-image"
                 src="@_article.ImageUrl"
                 alt="@_article.Title"
                 loading="lazy"
                 referrerpolicy="no-referrer" />
        }

        <a href="@($"/articles/{Id}/#comments-section")" class="article-comments-jump-btn">
            <i class="bi bi-chat-dots"></i> Перейти к комментариям
        </a>

        <!-- Контент -->
        <div class="article-view-content">
            @if (!string.IsNullOrEmpty(_article.ContentHtml))
            {
                @((MarkupString)AddHeadingIds(_article.ContentHtml))
            }
            else
            {
                @((MarkupString)RenderMarkdown(_article.Content))
            }
        </div>

        <!-- Читать полностью (только для RSS-статей) -->
        @* @if (!string.IsNullOrEmpty(_article.SourceUrl) && _article.AuthorId is null)
        {
            <a href="@_article.SourceUrl" target="_blank" class="article-read-full">
                <i class="bi bi-box-arrow-up-right"></i>
                Читать полностью на @GetDomain(_article.SourceUrl)
            </a>
        } *@

        <!-- Действия -->
        <div class="article-view-actions">
            @if (Auth.IsAuthenticated)
            {
                <button class="article-like-btn @(_liked ? "liked" : "")" @onclick="ToggleLike">
                    <i class="bi @(_liked ? "bi-heart-fill" : "bi-heart")"></i>
                    @_article.LikesCount
                </button>
                <button class="mod-report-btn" @onclick="() => _showReport = true">
                    <i class="bi bi-flag"></i> Пожаловаться
                </button>
            }
            else
            {
                <span class="article-meta"><i class="bi bi-heart"></i> @_article.LikesCount</span>
            }
            <button class="article-back" @onclick="() => Nav.NavigateTo(Nav.BaseUri)">
                <i class="bi bi-arrow-left"></i> В ленту
            </button>
        </div>

        <!-- Комментарии -->
        <div class="comments-section" id="comments-section">
            <h3 class="comments-title">
                <i class="bi bi-chat-dots"></i>
                Комментарии
                @if (_comments.Any())
                {
                    <span class="comments-count">@CountAll(_comments)</span>
                }
            </h3>

            @if (Auth.IsAuthenticated)
            {
                <div class="comment-form">
                    @if (_replyTo is not null)
                    {
                        <div class="comment-reply-banner">
                            <i class="bi bi-reply"></i>
                            Ответ пользователю <strong>@_replyTo.Username</strong>
                            <button @onclick="() => _replyTo = null" style="margin-left:auto;background:none;border:none;cursor:pointer;color:var(--text-muted)">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    }
                    <textarea class="comment-input" placeholder="Напишите комментарий..."
                              rows="3" @bind="_newComment" @bind:event="oninput"></textarea>
                    <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:8px">
                        @if (_replyTo is not null)
                        {
                            <button class="feed-sort-btn" @onclick="() => _replyTo = null">Отмена</button>
                        }
                        <button class="auth-btn" style="width:auto;padding:8px 20px"
                                @onclick="PostComment" disabled="@(_sending || string.IsNullOrWhiteSpace(_newComment))">
                            @if (_sending) { <span class="auth-spinner"></span> }
                            else { <i class="bi bi-send"></i> }
                            Отправить
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="comment-login-hint">
                    <i class="bi bi-chat-square-text"></i>
                    <a href="/login">Войдите</a>, чтобы оставить комментарий.
                </div>
            }

            @if (_commentsLoading)
            {
                <div class="admin-loading" style="padding:20px 0">
                    <span class="auth-spinner" style="border-color:var(--border);border-top-color:var(--accent)"></span>
                    Загрузка...
                </div>
            }
            else if (!_comments.Any())
            {
                <p class="comments-empty">Комментариев пока нет. Будьте первым!</p>
            }
            else
            {
                <div class="comments-list">
                    @foreach (var c in _comments)
                    {
                        @RenderComment(c, 0)
                    }
                </div>
            }
        </div>

    </div>
}

<!-- Модалка жалобы -->
@if (_showReport && _article is not null)
{
    <div class="modal-overlay" @onclick="() => _showReport = false">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-icon" style="color:#f57c00"><i class="bi bi-flag"></i></div>
            <h3 class="modal-title">Пожаловаться на статью</h3>
            <div style="display:flex;flex-direction:column;gap:10px;margin:12px 0">
                <select class="admin-select" style="width:100%" @bind="_reportTypeId">
                    <option value="1">Spam — спам</option>
                    <option value="2">Hate — ненависть</option>
                    <option value="3">Fake — ложь</option>
                </select>
                <textarea class="mod-reason-input" placeholder="Описание (необязательно)"
                          @bind="_reportDesc" rows="3"></textarea>
            </div>
            @if (_reportSent)
            {
                <p style="color:#2e7d32;font-size:13px">Жалоба отправлена. Спасибо!</p>
            }
            <div class="modal-actions">
                <button class="modal-btn-cancel" @onclick="() => _showReport = false">Отмена</button>
                @if (!_reportSent)
                {
                    <button class="modal-btn-confirm" style="background:#f57c00"
                            @onclick="SendReport" disabled="@_reportLoading">
                        @if (_reportLoading) { <span class="auth-spinner"></span> }
                        else { <span>Отправить</span> }
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private ArticleDto? _article;
    private bool _loading = true;
    private bool _liked;
    private bool _hasHtml => !string.IsNullOrEmpty(_article?.ContentHtml);

    private bool _showReport;
    private int _reportTypeId = 1;
    private string? _reportDesc;
    private bool _reportLoading, _reportSent;

    private List<CommentDto> _comments = [];
    private bool _commentsLoading = true;
    private string _newComment = "";
    private bool _sending;
    private CommentDto? _replyTo;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _commentsLoading = true;
        _comments = [];
        _replyTo = null;

        CommentSvc.OnCommentReceived -= OnCommentReceived;
        CommentSvc.OnCommentDeleted  -= OnCommentDeleted;

        _article = await ArticleSvc.GetByIdAsync(Id);

        if (_article is not null)
        {
            if (Auth.IsAuthenticated)
                _liked = await ArticleSvc.IsLikedAsync(Id);

            var source = !string.IsNullOrEmpty(_article.ContentHtml)
                    ? _article.ContentHtml
                    : _article.Content;
            HeadingsSvc.Set(ParseHeadings(source));
        }
        else
        {
            HeadingsSvc.Clear();
        }

        _loading = false;

        _comments = await CommentSvc.GetAsync(Id);
        _commentsLoading = false;

        CommentSvc.OnCommentReceived += OnCommentReceived;
        CommentSvc.OnCommentDeleted  += OnCommentDeleted;
        await CommentSvc.ConnectAsync(Id);
    }

    private async Task ToggleLike()
    {
        if (_article is null) return;
        _liked = !_liked;
        _article.LikesCount += _liked ? 1 : -1;
        var ok = await ArticleSvc.ToggleLikeAsync(_article.Id);
        if (!ok)
        {
            _liked = !_liked;
            _article.LikesCount += _liked ? 1 : -1;
        }
    }

    private static string GetDomain(string url)
    {
        try { return new Uri(url).Host.Replace("www.", ""); }
        catch { return url; }
    }

    public void Dispose()
    {
        HeadingsSvc.Clear();
        CommentSvc.OnCommentReceived -= OnCommentReceived;
        CommentSvc.OnCommentDeleted  -= OnCommentDeleted;
        _ = CommentSvc.DisconnectAsync();
    }

    private void OnCommentReceived(CommentDto c)
    {
        if (FindComment(_comments, c.Id) is not null) return;
        if (c.ParentCommentId is null)
            _comments.Add(c);
        else
        {
            var parent = FindComment(_comments, c.ParentCommentId.Value);
            parent?.Replies.Add(c);
        }
        InvokeAsync(StateHasChanged);
    }

    private void OnCommentDeleted(int id)
    {
        RemoveComment(_comments, id);
        InvokeAsync(StateHasChanged);
    }

    private static CommentDto? FindComment(List<CommentDto> list, int id)
    {
        foreach (var c in list)
        {
            if (c.Id == id) return c;
            var found = FindComment(c.Replies, id);
            if (found is not null) return found;
        }
        return null;
    }

    private static bool RemoveComment(List<CommentDto> list, int id)
    {
        var c = list.FirstOrDefault(x => x.Id == id);
        if (c is not null) { list.Remove(c); return true; }
        return list.Any(x => RemoveComment(x.Replies, id));
    }

    private static int CountAll(List<CommentDto> list) =>
        list.Count + list.Sum(c => CountAll(c.Replies));

    private async Task PostComment()
    {
        if (string.IsNullOrWhiteSpace(_newComment)) return;
        _sending = true;
        await CommentSvc.SendAsync(Id, _newComment.Trim(), _replyTo?.Id);
        _newComment = "";
        _replyTo    = null;
        _sending    = false;
    }

    private async Task DeleteComment(int commentId) =>
        await CommentSvc.DeleteAsync(Id, commentId);

    private RenderFragment RenderComment(CommentDto c, int depth) => __builder =>
    {
        __builder.OpenElement(0, "div");
        __builder.AddAttribute(1, "class", $"comment-item{(depth > 0 ? " comment-reply" : "")}");

        __builder.OpenElement(2, "div");
        __builder.AddAttribute(3, "class", "comment-header");
        __builder.OpenElement(4, "span");
        __builder.AddAttribute(5, "class", "comment-author");
        __builder.AddContent(6, c.Username);
        __builder.CloseElement();
        __builder.OpenElement(7, "span");
        __builder.AddAttribute(8, "class", "comment-date");
        __builder.AddContent(9, c.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm"));
        __builder.CloseElement();

        if (Auth.IsAuthenticated)
        {
            __builder.OpenElement(10, "button");
            __builder.AddAttribute(11, "class", "comment-reply-btn");
            __builder.AddAttribute(12, "onclick", EventCallback.Factory.Create(this, () => _replyTo = c));
            __builder.AddContent(13, "Ответить");
            __builder.CloseElement();

            if (Auth.CurrentUser?.Id == c.AuthorId ||
                Auth.CurrentUser?.Role is "Moderator" or "Admin")
            {
                __builder.OpenElement(14, "button");
                __builder.AddAttribute(15, "class", "comment-delete-btn");
                __builder.AddAttribute(16, "onclick", EventCallback.Factory.Create(this, () => DeleteComment(c.Id)));
                __builder.AddContent(17, "Удалить");
                __builder.CloseElement();
            }
        }
        __builder.CloseElement(); // comment-header

        __builder.OpenElement(18, "p");
        __builder.AddAttribute(19, "class", "comment-content");
        __builder.AddContent(20, c.Content);
        __builder.CloseElement();

        if (c.Replies.Any())
        {
            __builder.OpenElement(21, "div");
            __builder.AddAttribute(22, "class", "comment-replies");
            foreach (var reply in c.Replies)
                __builder.AddContent(23, RenderComment(reply, depth + 1));
            __builder.CloseElement();
        }

        __builder.CloseElement(); // comment-item
    };

    private static List<ArticleHeadingsService.Heading> ParseHeadings(string source)
    {
        var result = new List<ArticleHeadingsService.Heading>();

        // Если источник содержит HTML-теги — парсим как HTML
        if (System.Text.RegularExpressions.Regex.IsMatch(source, @"<h[123][\s>]"))
        {
            var matches = System.Text.RegularExpressions.Regex.Matches(
                source, @"<h([123])[^>]*>(.+?)</h\1>",
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            foreach (System.Text.RegularExpressions.Match m in matches)
            {
                var level  = "h" + m.Groups[1].Value;
                var text   = System.Text.RegularExpressions.Regex.Replace(m.Groups[2].Value, "<[^>]+>", "");
                var anchor = MakeAnchor(text);
                result.Add(new(level, text, anchor));
            }
        }
        else
        {
            // Парсим Markdown: # заголовок
            foreach (var line in source.Split('\n'))
            {
                var m3 = System.Text.RegularExpressions.Regex.Match(line, @"^### (.+)$");
                var m2 = System.Text.RegularExpressions.Regex.Match(line, @"^## (.+)$");
                var m1 = System.Text.RegularExpressions.Regex.Match(line, @"^# (.+)$");
                if      (m3.Success) result.Add(new("h3", m3.Groups[1].Value.Trim(), MakeAnchor(m3.Groups[1].Value.Trim())));
                else if (m2.Success) result.Add(new("h2", m2.Groups[1].Value.Trim(), MakeAnchor(m2.Groups[1].Value.Trim())));
                else if (m1.Success) result.Add(new("h1", m1.Groups[1].Value.Trim(), MakeAnchor(m1.Groups[1].Value.Trim())));
            }
        }

        return result;
    }

    private static string MakeAnchor(string text) =>
        "heading-" + System.Text.RegularExpressions.Regex.Replace(
            text.ToLowerInvariant(), @"[^a-z0-9а-я]+", "-").Trim('-');

    private async Task SendReport()
    {
        if (_article is null) return;
        _reportLoading = true;
        await ModerationSvc.CreateReportAsync(_article.Id, _reportTypeId, _reportDesc);
        _reportSent    = true;
        _reportLoading = false;
    }

    private static string AddHeadingIds(string html) =>
        System.Text.RegularExpressions.Regex.Replace(
            html, @"<h([123])([^>]*)>(.+?)</h\1>",
            m =>
            {
                var text   = System.Text.RegularExpressions.Regex.Replace(m.Groups[3].Value, "<[^>]+>", "");
                var anchor = MakeAnchor(text);
                return $"<h{m.Groups[1].Value} id=\"{anchor}\"{m.Groups[2].Value}>{m.Groups[3].Value}</h{m.Groups[1].Value}>";
            },
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);

    private static string RenderMarkdown(string md)
    {
        // Экранируем HTML чтобы теги не интерпретировались браузером
        // Сначала вырезаем блоки кода и заменяем плейсхолдерами
        var codeBlocks = new System.Collections.Generic.List<string>();
        md = System.Text.RegularExpressions.Regex.Replace(md, @"```(?:\w+)?\n([\s\S]+?)```", m =>
        {
            var code = m.Groups[1].Value
                .Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;");
            codeBlocks.Add($"<pre><code>{code}</code></pre>");
            return $"%%CODEBLOCK{codeBlocks.Count - 1}%%";
        });

        // Экранируем HTML во всём остальном тексте
        md = md.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;");

        // Заголовки
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^### (.+)$",
            m => { var t = m.Groups[1].Value; return $"<h3 id=\"{MakeAnchor(t)}\">{t}</h3>"; },
            System.Text.RegularExpressions.RegexOptions.Multiline);
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^## (.+)$",
            m => { var t = m.Groups[1].Value; return $"<h2 id=\"{MakeAnchor(t)}\">{t}</h2>"; },
            System.Text.RegularExpressions.RegexOptions.Multiline);
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^# (.+)$",
            m => { var t = m.Groups[1].Value; return $"<h1 id=\"{MakeAnchor(t)}\">{t}</h1>"; },
            System.Text.RegularExpressions.RegexOptions.Multiline);

        // Таблицы
        md = System.Text.RegularExpressions.Regex.Replace(md,
            @"((?:^\|.+\|\r?\n)+)",
            m =>
            {
                var rows = m.Value.Trim().Split('\n');
                var sb = new System.Text.StringBuilder("<table class=\"md-table\"><tbody>");
                bool headerDone = false;
                foreach (var row in rows)
                {
                    var trimmed = row.Trim();
                    if (trimmed.StartsWith("|") && trimmed.Replace("-", "").Replace("|", "").Replace(":", "").Trim() == "")
                        continue; // разделительная строка
                    var cells = trimmed.Trim('|').Split('|');
                    var tag = !headerDone ? "th" : "td";
                    sb.Append("<tr>");
                    foreach (var cell in cells)
                        sb.Append($"<{tag}>{cell.Trim()}</{tag}>");
                    sb.Append("</tr>");
                    headerDone = true;
                }
                sb.Append("</tbody></table>");
                return sb.ToString();
            },
            System.Text.RegularExpressions.RegexOptions.Multiline);

        // Инлайн-форматирование
        md = System.Text.RegularExpressions.Regex.Replace(md, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        md = System.Text.RegularExpressions.Regex.Replace(md, @"\*(.+?)\*",     "<em>$1</em>");
        md = System.Text.RegularExpressions.Regex.Replace(md, @"~~(.+?)~~",     "<del>$1</del>");
        md = System.Text.RegularExpressions.Regex.Replace(md, @"`(.+?)`",       "<code>$1</code>");
        md = System.Text.RegularExpressions.Regex.Replace(md, @"!\[(.+?)\]\((.+?)\)", "<img src=\"$2\" alt=\"$1\" style=\"max-width:100%\">");
        md = System.Text.RegularExpressions.Regex.Replace(md, @"\[(.+?)\]\((.+?)\)",  "<a href=\"$2\" target=\"_blank\">$1</a>");
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^&gt; (.+)$",   "<blockquote>$1</blockquote>", System.Text.RegularExpressions.RegexOptions.Multiline);
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^\*   (.+)$",   "<li>$1</li>", System.Text.RegularExpressions.RegexOptions.Multiline);
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^-   (.+)$",    "<li>$1</li>", System.Text.RegularExpressions.RegexOptions.Multiline);
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^- (.+)$",      "<li>$1</li>", System.Text.RegularExpressions.RegexOptions.Multiline);
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^\d+\.  (.+)$", "<li>$1</li>", System.Text.RegularExpressions.RegexOptions.Multiline);
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^\d+\. (.+)$",  "<li>$1</li>", System.Text.RegularExpressions.RegexOptions.Multiline);
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^---$",         "<hr>",         System.Text.RegularExpressions.RegexOptions.Multiline);

        // Обертываем параграфы
        md = string.Join("\n", md.Split('\n').Select(l =>
            l.StartsWith('<') || string.IsNullOrWhiteSpace(l) ? l : $"<p>{l}</p>"));

        // Возвращаем блоки кода
        for (int i = 0; i < codeBlocks.Count; i++)
            md = md.Replace($"<p>%%CODEBLOCK{i}%%</p>", codeBlocks[i])
                   .Replace($"%%CODEBLOCK{i}%%", codeBlocks[i]);

        return md;
    }
}
