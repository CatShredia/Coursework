@page "/saved"
@inject ArticleService ArticleSvc
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Избранное — Runews</PageTitle>

@if (!Auth.IsAuthenticated)
{
    Nav.NavigateTo("/login");
    return;
}

<div class="feed-toolbar">
    <span class="feed-toolbar-title">Избранное</span>
    @if (!_loading)
    {
        <span style="font-size:13px;color:var(--text-muted)">@_articles.Count статей</span>
    }
</div>

@if (_loading)
{
    @for (int i = 0; i < 4; i++)
    {
        <div class="skeleton-card" style="margin-bottom:12px">
            <div class="skeleton" style="height:20px;width:70%"></div>
            <div class="skeleton" style="height:14px;width:100%"></div>
            <div class="skeleton" style="height:14px;width:50%"></div>
        </div>
    }
}
else if (!_articles.Any())
{
    <div class="feed-empty">
        <i class="bi bi-bookmark"></i>
        <p>Вы ещё ничего не сохранили.</p>
        <a href="/" style="color:var(--accent);margin-top:8px;display:inline-block">← В ленту</a>
    </div>
}
else
{
    <div class="feed-list">
        @foreach (var article in _articles)
        {
            <div class="article-card" @onclick="() => GoTo(article.Id)">
                <div class="article-card-header">
                    <div class="article-title">
                        <a href="/articles/@article.Id" @onclick:stopPropagation="true">@article.Title</a>
                    </div>
                </div>

                <p class="article-preview">@article.Content</p>

                @if (article.Tags.Any())
                {
                    <div class="article-tags">
                        @foreach (var tag in article.Tags)
                        {
                            <span class="article-tag">@tag</span>
                        }
                    </div>
                }

                <div class="article-footer">
                    <span class="article-meta">
                        <i class="bi bi-calendar3"></i>
                        @article.PublishedAt.ToString("dd.MM.yyyy")
                    </span>
                    @if (!string.IsNullOrEmpty(article.SourceName))
                    {
                        <span class="article-meta"><i class="bi bi-rss"></i> @article.SourceName</span>
                    }
                    else if (!string.IsNullOrEmpty(article.Author))
                    {
                        <span class="article-meta"><i class="bi bi-person"></i> @article.Author</span>
                    }
                    <button class="article-like-btn @(_liked.Contains(article.Id) ? "liked" : "")"
                            style="margin-left:auto"
                            @onclick:stopPropagation="true"
                            @onclick="() => ToggleLike(article)">
                        <i class="bi @(_liked.Contains(article.Id) ? "bi-heart-fill" : "bi-heart")"></i>
                        @article.LikesCount
                    </button>
                    <button class="article-save-btn saved"
                            title="Убрать из избранного"
                            @onclick:stopPropagation="true"
                            @onclick="() => Unsave(article)">
                        <i class="bi bi-bookmark-fill"></i>
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<ArticleDto> _articles = [];
    private HashSet<int> _liked = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var articlesTask = ArticleSvc.GetSavedAsync();
        var likedTask    = ArticleSvc.GetLikedIdsAsync();
        await Task.WhenAll(articlesTask, likedTask);
        _articles = articlesTask.Result;
        _liked    = likedTask.Result;
        _loading  = false;
    }

    private void GoTo(int id) => Nav.NavigateTo("/articles/" + id);

    private async Task ToggleLike(ArticleDto article)
    {
        var wasLiked = _liked.Contains(article.Id);
        if (wasLiked) { _liked.Remove(article.Id); article.LikesCount--; }
        else          { _liked.Add(article.Id);    article.LikesCount++; }

        var ok = await ArticleSvc.ToggleLikeAsync(article.Id);
        if (!ok)
        {
            if (wasLiked) { _liked.Add(article.Id);    article.LikesCount++; }
            else          { _liked.Remove(article.Id); article.LikesCount--; }
        }
    }

    private async Task Unsave(ArticleDto article)
    {
        await ArticleSvc.ToggleSaveAsync(article.Id);
        _articles.Remove(article);
        _liked.Remove(article.Id);
    }
}
