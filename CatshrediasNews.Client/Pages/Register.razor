@page "/register"
@using Microsoft.JSInterop
@layout AuthLayout
@inject AuthService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Регистрация — Runews</PageTitle>

<div class="auth-card">
    <button class="auth-back" @onclick="GoBack">
        <i class="bi bi-arrow-left"></i> Назад
    </button>
    <div class="auth-logo">
        <span>Runews</span>
    </div>
    <h1 class="auth-title">Создать аккаунт</h1>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="auth-error">
            <i class="bi bi-exclamation-circle"></i> @_error
        </div>
    }

    <div class="auth-field">
        <label>Имя пользователя</label>
        <div class="input-wrap">
            <i class="bi bi-person"></i>
            <input type="text" placeholder="username"
                   @bind="_username" @bind:event="oninput" />
        </div>
    </div>

    <div class="auth-field">
        <label>Email</label>
        <div class="input-wrap @(_emailInvalid ? "input-invalid" : "")">
            <i class="bi bi-envelope"></i>
            <input type="email" placeholder="you@example.com"
                   @bind="_email" @bind:event="oninput"
                   @onblur="ValidateEmail" />
        </div>
        @if (_emailInvalid)
        {
            <span class="field-error">Введите корректный email (например: you@example.com)</span>
        }
    </div>

    <div class="auth-field">
        <label>Пароль</label>
        <div class="input-wrap @(_passwordInvalid ? "input-invalid" : "")">
            <i class="bi bi-lock"></i>
            <input type="@(_showPassword ? "text" : "password")"
                   placeholder="Минимум 6 символов"
                   @bind="_password" @bind:event="oninput"
                   @onblur="ValidatePassword" />
            <button class="input-eye" type="button" @onclick="TogglePassword">
                <i class="bi @(_showPassword ? "bi-eye-slash" : "bi-eye")"></i>
            </button>
        </div>
        @if (_passwordInvalid)
        {
            <span class="field-error">Пароль должен содержать минимум 6 символов</span>
        }
    </div>

    <div class="auth-field">
        <label>Повторите пароль</label>
        <div class="input-wrap @(_confirmInvalid ? "input-invalid" : "")">
            <i class="bi bi-lock-fill"></i>
            <input type="@(_showPassword ? "text" : "password")"
                   placeholder="Повторите пароль"
                   @bind="_confirm" @bind:event="oninput"
                   @onblur="ValidateConfirm" />
        </div>
        @if (_confirmInvalid)
        {
            <span class="field-error">Пароли не совпадают</span>
        }
    </div>

    <div class="auth-field">
        <label>Цвет аватара</label>
        <div class="avatar-color-row">
            @foreach (var color in _palette)
            {
                <button type="button"
                        class="avatar-color-swatch @(_avatarColor == color ? "selected" : "")"
                        style="background:@color"
                        @onclick="() => _avatarColor = color">
                    @if (_avatarColor == color)
                    {
                        <i class="bi bi-check-lg"></i>
                    }
                </button>
            }
        </div>
        <div class="avatar-preview">
            <i class="bi bi-person-circle" style="color:@_avatarColor"></i>
            <span style="color:var(--text-muted);font-size:12px">Предпросмотр</span>
        </div>
    </div>

    <button class="auth-btn" @onclick="Submit" disabled="@_loading">
        @if (_loading) { <span class="auth-spinner"></span> }
        else { <span>Зарегистрироваться</span> }
    </button>

    <div class="auth-links">
        <a href="/login">Уже есть аккаунт? Войти</a>
    </div>
</div>

@code {
    private string _username = "", _email = "", _password = "", _confirm = "";
    private string _avatarColor = "#1a73e8";
    private string? _error;
    private bool _loading, _showPassword, _emailInvalid, _passwordInvalid, _confirmInvalid;

    private static readonly string[] _palette =
    [
        "#1a73e8", "#e53935", "#43a047", "#fb8c00",
        "#8e24aa", "#00897b", "#f06292", "#546e7a"
    ];

    private void ValidateEmail()
    {
        _emailInvalid = !string.IsNullOrWhiteSpace(_email) &&
                        !System.Text.RegularExpressions.Regex.IsMatch(_email,
                            @"^[^@\s]+@[^@\s]+\.[^@\s]+$");
    }

    private void ValidatePassword()
    {
        _passwordInvalid = !string.IsNullOrWhiteSpace(_password) && _password.Length < 6;
    }

    private void ValidateConfirm()
    {
        _confirmInvalid = !string.IsNullOrWhiteSpace(_confirm) && _confirm != _password;
    }

    private void TogglePassword() => _showPassword = !_showPassword;
    
    private void GoBack() => JS.InvokeVoidAsync("history.back");

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        { _error = "Заполните все поля."; return; }
        ValidateEmail();
        ValidatePassword();
        ValidateConfirm();
        if (_emailInvalid || _passwordInvalid || _confirmInvalid) return;

        _loading = true; _error = null;
        _error = await Auth.RegisterAsync(new() { Username = _username, Email = _email, Password = _password, AvatarColor = _avatarColor });
        _loading = false;
        if (_error is null) Nav.NavigateTo("/");
    }
}
