@page "/moderation/queue"
@inject ModerationService ModerationSvc
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Очередь модерации — Runews</PageTitle>

@if (Auth.CurrentUser?.Role is not ("Moderator" or "Admin"))
{
    Nav.NavigateTo("/");
    return;
}

<div class="admin-page">
    <div class="admin-header">
        <h1 class="page-title" style="margin:0">Очередь модерации</h1>
        @if (!_loading)
        {
            <span class="admin-count">На проверке: @_queue.Count</span>
        }
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="@(_isError ? "auth-error" : "auth-success")" style="margin-bottom:4px">
            <i class="bi @(_isError ? "bi-exclamation-circle" : "bi-check-circle")"></i>
            @_message
        </div>
    }

    @if (_loading)
    {
        <div class="admin-loading">
            <span class="auth-spinner" style="border-color:var(--border);border-top-color:var(--accent)"></span>
            Загрузка...
        </div>
    }
    else if (!_queue.Any())
    {
        <div class="feed-empty">
            <i class="bi bi-check2-all"></i>
            <p>Очередь пуста — все статьи проверены.</p>
        </div>
    }
    else
    {
        <div class="mod-queue">
            @foreach (var article in _queue)
            {
                <div class="mod-card">
                    @if (!string.IsNullOrEmpty(article.ImageUrl))
                    {
                        <img src="@article.ImageUrl" class="mod-card-img" alt="" />
                    }
                    <div class="mod-card-body">
                        <div class="mod-card-meta">
                            @if (!string.IsNullOrEmpty(article.SourceName))
                            {
                                <span class="mod-source">
                                    <i class="bi bi-rss"></i> @article.SourceName
                                </span>
                            }
                            else if (!string.IsNullOrEmpty(article.Author))
                            {
                                <span class="mod-source">
                                    <i class="bi bi-person"></i> @article.Author
                                </span>
                            }
                            <span class="mod-date">
                                <i class="bi bi-calendar3"></i>
                                @article.PublishedAt.ToString("dd.MM.yyyy HH:mm")
                            </span>
                        </div>

                        <a href="/moderation/review/@article.Id" class="mod-card-title">
                            @article.Title
                        </a>

                        @if (article.Tags.Any())
                        {
                            <div class="mod-card-tags">
                                @foreach (var tag in article.Tags)
                                {
                                    <span class="article-tag">@tag</span>
                                }
                            </div>
                        }

                        <p class="mod-card-preview">
                            @(article.Content.Length > 220
                                ? article.Content[..220] + "…"
                                : article.Content)
                        </p>

                        <div class="mod-card-actions">
                            <a href="/moderation/review/@article.Id" class="mod-btn mod-btn-review">
                                <i class="bi bi-search"></i> Проверить
                            </a>
                            <button class="mod-btn mod-btn-approve"
                                    disabled="@(_busy == article.Id)"
                                    @onclick="() => Approve(article)">
                                <i class="bi bi-check-lg"></i> Одобрить
                            </button>
                            <button class="mod-btn mod-btn-reject"
                                    disabled="@(_busy == article.Id)"
                                    @onclick="() => GoReview(article.Id)">
                                <i class="bi bi-x-lg"></i> Отклонить
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ArticleDto> _queue = [];
    private bool _loading = true;
    private int? _busy;
    private string? _message;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        _queue   = await ModerationSvc.GetQueueAsync();
        _loading = false;
    }

    private async Task Approve(ArticleDto article)
    {
        _busy = article.Id;
        var ok = await ModerationSvc.ApproveAsync(article.Id);
        if (ok) { _queue.Remove(article); ShowMsg("Статья опубликована.", false); }
        else      ShowMsg("Ошибка при одобрении.", true);
        _busy = null;
    }

    private void GoReview(int id) => Nav.NavigateTo($"/moderation/review/{id}");

    private void ShowMsg(string msg, bool isError) { _message = msg; _isError = isError; }
}
