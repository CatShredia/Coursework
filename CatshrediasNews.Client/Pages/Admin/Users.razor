@page "/admin/users"
@inject AuthService Auth
@inject AdminService AdminSvc
@inject NavigationManager Nav

<PageTitle>Пользователи — Runews</PageTitle>

@if (Auth.CurrentUser?.Role != "Admin")
{
    Nav.NavigateTo("/");
    return;
}

<div class="admin-page">
    <div class="admin-header">
        <h1 class="page-title" style="margin:0">Управление пользователями</h1>
        <span class="admin-count">Всего: @_users.Count</span>
    </div>

    <!-- Поиск и фильтр -->
    <div class="admin-toolbar">
        <div class="input-wrap" style="max-width:320px;flex:1">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Поиск по имени или email..."
                   @bind="_search" @bind:event="oninput" />
        </div>
        <select class="admin-select" @bind="_roleFilter">
            <option value="">Все роли</option>
            <option value="Admin">Admin</option>
            <option value="Moderator">Moderator</option>
            <option value="Publicist">Publicist</option>
            <option value="User">User</option>
        </select>
        <select class="admin-select" @bind="_statusFilter">
            <option value="">Все статусы</option>
            <option value="active">Активные</option>
            <option value="blocked">Заблокированные</option>
        </select>
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="@(_isError ? "auth-error" : "auth-success")" style="margin-bottom:16px">
            <i class="bi @(_isError ? "bi-exclamation-circle" : "bi-check-circle")"></i>
            @_message
        </div>
    }

    @if (_loading)
    {
        <div class="admin-loading"><span class="auth-spinner" style="border-color:var(--border);border-top-color:var(--accent)"></span> Загрузка...</div>
    }
    else if (!_filtered.Any())
    {
        <div class="feed-empty"><i class="bi bi-people"></i><p>Пользователи не найдены.</p></div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Пользователь</th>
                        <th>Email</th>
                        <th>Роль</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in _filtered)
                    {
                        <tr class="@(user.IsBlocked ? "row-blocked" : "")">
                            <td class="td-id">@user.Id</td>
                            <td>
                                <div class="user-cell">
                                    <div class="user-avatar-sm">
                                        <i class="bi bi-person-circle"></i>
                                    </div>
                                    <span>@user.Username</span>
                                </div>
                            </td>
                            <td class="td-email">@user.Email</td>
                            <td>
                                @if (user.Id != Auth.CurrentUser!.Id && user.Role != "Admin")
                                {
                                    <select class="admin-select" style="width:auto;font-size:12px;padding:4px 8px"
                                            value="@user.Role"
                                            @onchange="e => ChangeRole(user, e.Value?.ToString())">
                                        <option value="Moderator">Moderator</option>
                                        <option value="Publicist">Publicist</option>
                                        <option value="User">User</option>
                                    </select>
                                }
                                else
                                {
                                    <span class="role-badge role-@user.Role.ToLower()">@user.Role</span>
                                }
                            </td>
                            <td>
                                @if (user.IsBlocked)
                                {
                                    <span class="status-badge status-blocked">
                                        <i class="bi bi-slash-circle"></i> Заблокирован
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-active">
                                        <i class="bi bi-check-circle"></i> Активен
                                    </span>
                                }
                            </td>
                            <td>
                                <div class="action-btns">
                                    @if (user.Id != Auth.CurrentUser!.Id)
                                    {
                                        @if (user.IsBlocked)
                                        {
                                            <button class="action-btn action-btn-success"
                                                    title="Разблокировать"
                                                    @onclick="() => Unblock(user)">
                                                <i class="bi bi-unlock"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="action-btn action-btn-warn"
                                                    title="Заблокировать"
                                                    @onclick="() => Block(user)">
                                                <i class="bi bi-slash-circle"></i>
                                            </button>
                                        }
                                        <button class="action-btn action-btn-danger"
                                                title="Удалить"
                                                @onclick="() => AskDelete(user)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <span style="color:var(--text-muted);font-size:12px">Вы</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Модальное окно подтверждения удаления -->
@if (_deleteTarget is not null)
{
    <div class="modal-overlay" @onclick="() => _deleteTarget = null">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-icon"><i class="bi bi-exclamation-triangle"></i></div>
            <h3 class="modal-title">Удалить пользователя?</h3>
            <p class="modal-text">
                Аккаунт <strong>@_deleteTarget.Username</strong> (@_deleteTarget.Email)
                будет удалён безвозвратно.
            </p>
            <div class="modal-actions">
                <button class="modal-btn-cancel" @onclick="() => _deleteTarget = null">Отмена</button>
                <button class="modal-btn-confirm" @onclick="ConfirmDelete" disabled="@_actionLoading">
                    @if (_actionLoading) { <span class="auth-spinner"></span> }
                    else { <span>Удалить</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<UserInfo> _users = [];
    private string _search = "", _roleFilter = "", _statusFilter = "";
    private string? _message;
    private bool _isError, _loading = true, _actionLoading;
    private UserInfo? _deleteTarget;

    private List<UserInfo> _filtered => _users
        .Where(u => (string.IsNullOrEmpty(_search) ||
                     u.Username.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                     u.Email.Contains(_search, StringComparison.OrdinalIgnoreCase))
                 && (string.IsNullOrEmpty(_roleFilter) || u.Role == _roleFilter)
                 && (_statusFilter == "" ||
                     (_statusFilter == "blocked" && u.IsBlocked) ||
                     (_statusFilter == "active"  && !u.IsBlocked)))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        _users   = await AdminSvc.GetUsersAsync();
        _loading = false;
    }

    private async Task ChangeRole(UserInfo user, string? role)
    {
        if (string.IsNullOrEmpty(role) || role == user.Role) return;
        _actionLoading = true;
        var ok = await AdminSvc.SetRoleAsync(user.Id, role);
        if (ok) { user.Role = role; ShowMsg($"Роль {user.Username} изменена на {role}.", false); }
        else      ShowMsg("Ошибка при смене роли.", true);
        _actionLoading = false;
    }

    private async Task Block(UserInfo user)
    {
        _actionLoading = true;
        var ok = await AdminSvc.BlockUserAsync(user.Id);
        if (ok) { user.IsBlocked = true; ShowMsg("Пользователь заблокирован.", false); }
        else      ShowMsg("Ошибка при блокировке.", true);
        _actionLoading = false;
    }

    private async Task Unblock(UserInfo user)
    {
        _actionLoading = true;
        var ok = await AdminSvc.UnblockUserAsync(user.Id);
        if (ok) { user.IsBlocked = false; ShowMsg("Пользователь разблокирован.", false); }
        else      ShowMsg("Ошибка при разблокировке.", true);
        _actionLoading = false;
    }

    private void AskDelete(UserInfo user) => _deleteTarget = user;

    private async Task ConfirmDelete()
    {
        if (_deleteTarget is null) return;
        _actionLoading = true;
        var ok = await AdminSvc.DeleteUserAsync(_deleteTarget.Id);
        if (ok) { _users.Remove(_deleteTarget); ShowMsg("Пользователь удалён.", false); }
        else      ShowMsg("Ошибка при удалении.", true);
        _deleteTarget  = null;
        _actionLoading = false;
    }

    private void ShowMsg(string msg, bool isError)
    {
        _message = msg; _isError = isError;
    }
}
