@page "/admin/rss"
@using CatshrediasNews.Client.Models
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@inject AuthService Auth
@inject AdminService AdminSvc
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IWebAssemblyHostEnvironment HostEnv

<PageTitle>Сторонние Источники — Runews</PageTitle>

@if (Auth.CurrentUser?.Role != "Admin")
{
    Nav.NavigateTo("/");
    return;
}

<div class="admin-page">
    <div class="admin-header">
        <h1 class="page-title" style="margin:0">Сторонние Источники</h1>
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="@(_isError ? "auth-error" : "auth-success")" style="margin-bottom:16px">
            <i class="bi @(_isError ? "bi-exclamation-circle" : "bi-check-circle")"></i> @_message
        </div>
    }
    @if (_isProduction)
    {
        <div class="auth-error" style="margin-bottom:16px">
            <i class="bi bi-lock"></i> В Production изменение и выгрузка сторонних источников отключены.
        </div>
    }

    <!-- Панель управления парсером -->
    <div class="profile-card" style="margin-bottom:24px;gap:24px;flex-wrap:wrap">
        <div style="display:flex;flex-direction:column;gap:6px">
            <span style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted)">Интервал парсинга</span>
            <div style="display:flex;align-items:center;gap:8px">
                <input type="number" min="1" max="10080"
                       style="width:90px;padding:8px 12px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;color:var(--text-primary);background:var(--bg);outline:none"
                       @bind="_interval" />
                <span style="font-size:13px;color:var(--text-muted)">мин.</span>
                <button class="auth-btn" style="width:auto;padding:8px 16px" @onclick="SaveInterval" disabled="@_saving">
                    @if (_saving) { <span class="auth-spinner"></span> } else { <i class="bi bi-check-lg"></i> }
                    Сохранить
                </button>
            </div>
        </div>
        <div style="display:flex;align-items:flex-end">
            <button class="auth-btn" style="width:auto;padding:8px 20px;background:#43a047" @onclick="TriggerNow" disabled="@_triggering">
                @if (_triggering) { <span class="auth-spinner"></span> } else { <i class="bi bi-play-fill"></i> }
                Запустить парсинг сейчас
            </button>
        </div>
    </div>

    <!-- Форма добавления источника -->
    <div class="profile-section" style="margin-bottom:24px;opacity:@(_isProduction ? "0.6" : "1")">
        <h2 class="profile-section-title">Добавить источник</h2>

        <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;margin-bottom:12px">
            <div class="auth-field" style="flex:1;min-width:160px">
                <label>Название</label>
                <div class="input-wrap"><i class="bi bi-rss"></i>
                    <input type="text" placeholder="Habr" @bind="_newName" @bind:event="oninput" disabled="@_isProduction" />
                </div>
            </div>
            <div class="auth-field" style="flex:2;min-width:240px">
                <label>URL</label>
                <div class="input-wrap"><i class="bi bi-link-45deg"></i>
                    <input type="url" placeholder="https://..." @bind="_newUrl" @bind:event="oninput" disabled="@_isProduction" />
                </div>
            </div>
            <div class="auth-field">
                <label>Тип</label>
                <select class="admin-select" @bind="_newType" disabled="@_isProduction">
                    <option value="Rss">RSS</option>
                    <option value="Scraper">Скрапер</option>
                </select>
            </div>
            <div class="auth-field" style="justify-content:flex-end">
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:600;font-size:13px;color:var(--text-secondary)">
                    <input type="checkbox" @bind="_newTrusted" style="width:16px;height:16px;cursor:pointer" disabled="@_isProduction" />
                    Доверенный
                </label>
            </div>
        </div>

        @if (_newType == "Scraper")
        {
            <div class="scraper-fields">
                <p style="font-size:13px;font-weight:600;color:var(--text-primary);margin-bottom:6px">
                    <i class="bi bi-info-circle" style="color:var(--accent)"></i> Как найти CSS-селекторы
                </p>
                <ol style="font-size:12px;color:var(--text-secondary);padding-left:18px;margin-bottom:12px;line-height:1.8">
                    <li>Откройте нужный сайт в браузере и нажмите <kbd>F12</kbd> (или <kbd>Ctrl+Shift+I</kbd>).</li>
                    <li>Нажмите иконку <kbd>&#x2316;</kbd> (инспектор элементов) в левом верхнем углу DevTools.</li>
                    <li>Кликните на нужный элемент на странице — он подсветится в коде.</li>
                    <li>В панели Elements кликните правой кнопкой на тег → <strong>Copy → Copy selector</strong>.</li>
                    <li>Вставьте скопированный селектор в нужное поле ниже.</li>
                </ol>
                <p style="font-size:12px;color:var(--text-muted);margin-bottom:12px">
                    <i class="bi bi-lightbulb"></i>
                    <strong>Совет:</strong> для <em>Селектора ссылок</em> выбирайте элемент на странице-каталоге (список статей).
                    Для остальных — на странице отдельной статьи. Пример: <code>h1.article-title</code>, <code>.post-body</code>, <code>img.cover</code>.
                </p>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                    <div class="auth-field">
                        <label>Селектор ссылок <span style="color:#e53935">*</span></label>
                        <div class="input-wrap"><i class="bi bi-link"></i>
                            <input type="text" placeholder="a.article-link" @bind="_newLinkSel" @bind:event="oninput" disabled="@_isProduction" />
                        </div>
                    </div>
                    <div class="auth-field">
                        <label>Селектор заголовка</label>
                        <div class="input-wrap"><i class="bi bi-type-h1"></i>
                            <input type="text" placeholder="h1.title" @bind="_newTitleSel" @bind:event="oninput" disabled="@_isProduction" />
                        </div>
                    </div>
                    <div class="auth-field">
                        <label>Селектор контента</label>
                        <div class="input-wrap"><i class="bi bi-text-paragraph"></i>
                            <input type="text" placeholder=".article-body" @bind="_newContentSel" @bind:event="oninput" disabled="@_isProduction" />
                        </div>
                    </div>
                    <div class="auth-field">
                        <label>Селектор даты</label>
                        <div class="input-wrap"><i class="bi bi-calendar3"></i>
                            <input type="text" placeholder="time.published" @bind="_newDateSel" @bind:event="oninput" disabled="@_isProduction" />
                        </div>
                    </div>
                    <div class="auth-field">
                        <label>Селектор изображения</label>
                        <div class="input-wrap"><i class="bi bi-image"></i>
                            <input type="text" placeholder=".cover img" @bind="_newImageSel" @bind:event="oninput" disabled="@_isProduction" />
                        </div>
                    </div>
                </div>
            </div>
        }

        <button class="auth-btn" style="width:auto;padding:9px 20px;margin-top:12px" @onclick="AddSource" disabled="@(_adding || _isProduction)">
            @if (_adding) { <span class="auth-spinner"></span> } else { <i class="bi bi-plus-lg"></i> }
            Добавить
        </button>
    </div>

    <!-- Таблица источников -->
    @if (_loading)
    {
        <div class="admin-loading">
            <span class="auth-spinner" style="border-color:var(--border);border-top-color:var(--accent)"></span>
            Загрузка...
        </div>
    }
    else if (!_sources.Any())
    {
        <div class="feed-empty"><i class="bi bi-rss"></i><p>Источников нет. Добавьте первый.</p></div>
    }
    else
    {
        <div style="display:flex;justify-content:flex-end;margin-bottom:10px">
            <button class="auth-btn" style="width:auto;padding:8px 16px" @onclick="SaveExternalSources" disabled="@(_savingSources || _isProduction)">
                @if (_savingSources) { <span class="auth-spinner"></span> } else { <i class="bi bi-floppy"></i> }
                Сохранить Сторонние источники
            </button>
        </div>

        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>URL</th>
                        <th>Тип</th>
                        <th>Доверенный</th>
                        <th>Статус</th>
                        <th>Последний парсинг</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var src in _sources)
                    {
                        @if (_editId == src.Id)
                        {
                            <tr style="background:var(--accent-light)">
                                <td><input class="admin-inline-input" @bind="_editName" /></td>
                                <td><input class="admin-inline-input" @bind="_editUrl" /></td>
                                <td>
                                    <select class="admin-select" style="font-size:12px;padding:4px 8px" @bind="_editType">
                                        <option value="Rss">RSS</option>
                                        <option value="Scraper">Скрапер</option>
                                    </select>
                                </td>
                                <td style="text-align:center">
                                    <input type="checkbox" @bind="_editTrusted" style="width:16px;height:16px;cursor:pointer" />
                                </td>
                                <td colspan="2">
                                    @if (_editType == "Scraper")
                                    {
                                        <div style="display:flex;flex-direction:column;gap:4px;font-size:12px">
                                            <input class="admin-inline-input" placeholder="Ссылки (обязательно)" @bind="_editLinkSel" />
                                            <input class="admin-inline-input" placeholder="Заголовок" @bind="_editTitleSel" />
                                            <input class="admin-inline-input" placeholder="Контент" @bind="_editContentSel" />
                                            <input class="admin-inline-input" placeholder="Дата" @bind="_editDateSel" />
                                            <input class="admin-inline-input" placeholder="Изображение" @bind="_editImageSel" />
                                        </div>
                                    }
                                    else
                                    {
                                        <span style="color:var(--text-muted);font-size:12px">Режим редактирования</span>
                                    }
                                </td>
                                <td>
                                    <div class="action-btns">
                                        <button class="action-btn action-btn-success" title="Сохранить" @onclick="() => SaveEdit(src)">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                        <button class="action-btn" title="Отмена" @onclick="CancelEdit">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            <tr>
                                <td style="font-weight:600">@src.Name</td>
                                <td>
                                    <a href="@src.Url" target="_blank" style="color:var(--accent);font-size:12px;word-break:break-all">
                                        @(src.Url.Length > 50 ? src.Url[..50] + "…" : src.Url)
                                    </a>
                                </td>
                                <td>
                                    @if (src.SourceType == "Scraper")
                                    {
                                        <span class="status-badge status-pending"><i class="bi bi-code-slash"></i> Скрапер</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge"><i class="bi bi-rss"></i> RSS</span>
                                    }
                                </td>
                                <td style="text-align:center">
                                    @if (src.IsTrusted)
                                    {
                                        <span class="status-badge status-active"><i class="bi bi-shield-check"></i> Да</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge"><i class="bi bi-shield"></i> Нет</span>
                                    }
                                </td>
                                <td>
                                    @if (src.IsEnabled)
                                    {
                                        <span class="status-badge status-active"><i class="bi bi-check-circle"></i> Включён</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-blocked"><i class="bi bi-slash-circle"></i> Отключён</span>
                                    }
                                </td>
                                <td style="font-size:12px;color:var(--text-muted);white-space:nowrap">
                                    @(src.LastFetchedAt.HasValue ? src.LastFetchedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "—")
                                </td>
                                <td>
                                    <div class="action-btns">
                                        @if (src.IsEnabled)
                                        {
                                            <button class="action-btn action-btn-warn" title="Отключить" @onclick="() => ToggleEnabled(src, false)" disabled="@_isProduction">
                                                <i class="bi bi-pause-fill"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="action-btn action-btn-success" title="Включить" @onclick="() => ToggleEnabled(src, true)" disabled="@_isProduction">
                                                <i class="bi bi-play-fill"></i>
                                            </button>
                                        }
                                        <button class="action-btn" title="Редактировать" @onclick="() => StartEdit(src)" disabled="@_isProduction">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="action-btn action-btn-danger" title="Удалить" @onclick="() => AskDelete(src)" disabled="@_isProduction">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (_deleteTarget is not null)
{
    <div class="modal-overlay" @onclick="() => _deleteTarget = null">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-icon"><i class="bi bi-exclamation-triangle"></i></div>
            <h3 class="modal-title">Удалить источник?</h3>
            <p class="modal-text">«@_deleteTarget.Name» будет удалён безвозвратно.</p>
            <div class="modal-actions">
                <button class="modal-btn-cancel" @onclick="() => _deleteTarget = null">Отмена</button>
                <button class="modal-btn-confirm" @onclick="ConfirmDelete" disabled="@_deleting">
                    @if (_deleting) { <span class="auth-spinner"></span> } else { <span>Удалить</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<RssSourceDto> _sources = [];
    private bool _loading = true, _saving, _triggering, _adding, _deleting;
    private bool _savingSources;
    private string? _message;
    private bool _isError;
    private int _interval = 15;

    // Форма добавления
    private string _newName = "", _newUrl = "", _newType = "Rss";
    private bool   _newTrusted = true;
    private string? _newLinkSel, _newTitleSel, _newContentSel, _newDateSel, _newImageSel;

    // Форма редактирования
    private int?   _editId;
    private string _editName = "", _editUrl = "", _editType = "Rss";
    private bool   _editTrusted;
    private string? _editLinkSel, _editTitleSel, _editContentSel, _editDateSel, _editImageSel;

    private RssSourceDto? _deleteTarget;
    private bool _isProduction;

    protected override async Task OnInitializedAsync()
    {
        _isProduction = HostEnv.IsProduction();
        _sources  = await AdminSvc.GetSourcesAsync();
        _interval = await AdminSvc.GetRssIntervalAsync();
        _loading  = false;
    }

    private async Task SaveInterval()
    {
        if (_interval < 1) { ShowMsg("Интервал должен быть не менее 1 минуты.", true); return; }
        _saving = true;
        var ok = await AdminSvc.SetRssIntervalAsync(_interval);
        ShowMsg(ok ? $"Интервал изменён на {_interval} мин." : "Ошибка при сохранении.", !ok);
        _saving = false;
    }

    private async Task TriggerNow()
    {
        _triggering = true;
        var ok = await AdminSvc.TriggerRssAsync();
        ShowMsg(ok ? "Парсинг запущен." : "Ошибка запуска.", !ok);
        _triggering = false;
    }

    private async Task AddSource()
    {
        if (_isProduction) { ShowMsg("В Production изменение источников отключено.", true); return; }
        if (string.IsNullOrWhiteSpace(_newName) || string.IsNullOrWhiteSpace(_newUrl))
        { ShowMsg("Заполните название и URL.", true); return; }
        if (_newType == "Scraper" && string.IsNullOrWhiteSpace(_newLinkSel))
        { ShowMsg("Для скрапера обязателен селектор ссылок.", true); return; }

        _adding = true;
        var src = await AdminSvc.CreateSourceAsync(
            _newName.Trim(), _newUrl.Trim(), _newTrusted, _newType,
            _newLinkSel, _newTitleSel, _newContentSel, _newDateSel, _newImageSel);
        if (src is not null)
        {
            _sources.Add(src);
            _newName = ""; _newUrl = ""; _newType = "Rss"; _newTrusted = true;
            _newLinkSel = _newTitleSel = _newContentSel = _newDateSel = _newImageSel = null;
            ShowMsg("Источник добавлен.", false);
        }
        else ShowMsg("Ошибка при добавлении.", true);
        _adding = false;
    }

    private void StartEdit(RssSourceDto src)
    {
        _editId = src.Id; _editName = src.Name; _editUrl = src.Url;
        _editTrusted = src.IsTrusted; _editType = src.SourceType;
        _editLinkSel = src.LinkSelector; _editTitleSel = src.TitleSelector;
        _editContentSel = src.ContentSelector; _editDateSel = src.DateSelector;
        _editImageSel = src.ImageSelector;
    }

    private void CancelEdit() => _editId = null;

    private async Task SaveEdit(RssSourceDto src)
    {
        if (_isProduction) { ShowMsg("В Production изменение источников отключено.", true); return; }
        if (_editType == "Scraper" && string.IsNullOrWhiteSpace(_editLinkSel))
        { ShowMsg("Для скрапера обязателен селектор ссылок.", true); return; }

        var ok = await AdminSvc.UpdateSourceAsync(
            src.Id, _editName.Trim(), _editUrl.Trim(), _editTrusted, _editType,
            _editLinkSel, _editTitleSel, _editContentSel, _editDateSel, _editImageSel);
        if (ok)
        {
            var idx = _sources.IndexOf(src);
            _sources[idx] = new RssSourceDto
            {
                Id = src.Id, Name = _editName.Trim(), Url = _editUrl.Trim(),
                IsTrusted = _editTrusted, IsEnabled = src.IsEnabled,
                LastFetchedAt = src.LastFetchedAt, SourceType = _editType,
                LinkSelector = _editLinkSel, TitleSelector = _editTitleSel,
                ContentSelector = _editContentSel, DateSelector = _editDateSel,
                ImageSelector = _editImageSel
            };
            ShowMsg("Источник обновлён.", false);
        }
        else ShowMsg("Ошибка при обновлении.", true);
        _editId = null;
    }

    private async Task ToggleEnabled(RssSourceDto src, bool enabled)
    {
        if (_isProduction) { ShowMsg("В Production изменение источников отключено.", true); return; }
        var ok = await AdminSvc.SetSourceEnabledAsync(src.Id, enabled);
        if (ok)
        {
            var idx = _sources.IndexOf(src);
            _sources[idx] = new RssSourceDto
            {
                Id = src.Id, Name = src.Name, Url = src.Url, IsTrusted = src.IsTrusted,
                IsEnabled = enabled, LastFetchedAt = src.LastFetchedAt, SourceType = src.SourceType,
                LinkSelector = src.LinkSelector, TitleSelector = src.TitleSelector,
                ContentSelector = src.ContentSelector, DateSelector = src.DateSelector,
                ImageSelector = src.ImageSelector
            };
            ShowMsg(enabled ? "Источник включён." : "Источник отключён.", false);
        }
        else ShowMsg("Ошибка.", true);
    }

    private void AskDelete(RssSourceDto src) => _deleteTarget = src;

    private async Task ConfirmDelete()
    {
        if (_isProduction) { ShowMsg("В Production изменение источников отключено.", true); return; }
        if (_deleteTarget is null) return;
        _deleting = true;
        var ok = await AdminSvc.DeleteSourceAsync(_deleteTarget.Id);
        if (ok) { _sources.Remove(_deleteTarget); ShowMsg("Источник удалён.", false); }
        else ShowMsg("Ошибка при удалении.", true);
        _deleteTarget = null;
        _deleting = false;
    }

    private void ShowMsg(string msg, bool isError) { _message = msg; _isError = isError; }

    private async Task SaveExternalSources()
    {
        if (_isProduction) { ShowMsg("В Production выгрузка RssSources отключена.", true); return; }
        _savingSources = true;
        var (ok, fileName, content) = await AdminSvc.ExportSourcesSqlAsync();
        if (ok && fileName is not null && content is not null)
        {
            await JS.InvokeVoidAsync("runews.downloadTextFile", fileName, content, "application/sql;charset=utf-8");
            ShowMsg("SQL-файл со сторонними источниками выгружен.", false);
        }
        else
        {
            ShowMsg("Не удалось выгрузить SQL-файл.", true);
        }
        _savingSources = false;
    }
}
