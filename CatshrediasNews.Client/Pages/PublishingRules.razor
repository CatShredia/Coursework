@page "/publishing-rules"
@using CatshrediasNews.Client.Services

<PageTitle>@L["Rules_PageTitle"]</PageTitle>

<div class="info-page">
    <a href="/publicist/create" class="article-back">
        <i class="bi bi-arrow-left"></i> @L["Common_Back"] @L["Guide_BackToEditor"]
    </a>

    <div>
        <h1 class="info-page-title">@L["Rules_Title"]</h1>
        <p class="info-page-subtitle">@L["Rules_Subtitle"]</p>
    </div>

    <div class="rules-section">
        <div class="rules-section-header">
            <div class="rules-section-icon"><i class="bi bi-check2-circle"></i></div>
            <h2>@L["Rules_GeneralTitle"]</h2>
        </div>
        <ul class="rules-list">
            <li>@L["Rules_General1"]</li>
            <li>@L["Rules_General2"]</li>
            <li>@L["Rules_General3"]</li>
            <li>@L["Rules_General4"]</li>
            <li>@L["Rules_General5"]</li>
        </ul>
    </div>

    <div class="rules-section rules-section-danger">
        <div class="rules-section-header">
            <div class="rules-section-icon danger"><i class="bi bi-slash-circle"></i></div>
            <h2>@L["Rules_ForbiddenTitle"]</h2>
        </div>
        <ul class="rules-list">
            <li>@L["Rules_Forbidden1"]</li>
            <li>@L["Rules_Forbidden2"]</li>
            <li>@L["Rules_Forbidden3"]</li>
            <li>@L["Rules_Forbidden4"]</li>
            <li>@L["Rules_Forbidden5"]</li>
            <li>@L["Rules_Forbidden6"]</li>
        </ul>
    </div>

    <div class="rules-section">
        <div class="rules-section-header">
            <div class="rules-section-icon"><i class="bi bi-pencil-square"></i></div>
            <h2>@L["Rules_FormatTitle"]</h2>
        </div>
        <ul class="rules-list">
            <li>@L["Rules_Format1"]</li>
            <li>@L["Rules_Format2"]</li>
            <li>@L["Rules_Format3"]</li>
            <li>@L["Rules_Format4"]</li>
            <li>@L["Rules_Format5"]</li>
        </ul>
    </div>

    <div class="rules-section">
        <div class="rules-section-header">
            <div class="rules-section-icon"><i class="bi bi-shield-check"></i></div>
            <h2>@L["Rules_ModerationTitle"]</h2>
        </div>
        <div class="rules-flow">
            <div class="rules-flow-step">
                <div class="rules-flow-num">1</div>
                <div>
                    <strong>@L["Rules_Step1Title"]</strong>
                    <p>@string.Format(L["Rules_Step1Text"], L["Common_Save"], L.ArticleStatus("PendingReview"))</p>
                </div>
            </div>
            <div class="rules-flow-step">
                <div class="rules-flow-num">2</div>
                <div>
                    <strong>@L["Rules_Step2Title"]</strong>
                    <p>@L["Rules_Step2Text"]</p>
                </div>
            </div>
            <div class="rules-flow-step">
                <div class="rules-flow-num">3</div>
                <div>
                    <strong>@L["Rules_Step3Title"]</strong>
                    <p>@string.Format(L["Rules_Step3Text"], L.ArticleStatus("Published"), L.ArticleStatus("Rejected"))</p>
                </div>
            </div>
        </div>
    </div>

    <div class="rules-section">
        <div class="rules-section-header">
            <div class="rules-section-icon"><i class="bi bi-exclamation-triangle"></i></div>
            <h2>@L["Rules_ConsequencesTitle"]</h2>
        </div>
        <div class="rules-consequences">
            <div class="rules-consequence">
                <i class="bi bi-x-circle" style="color:#f57c00"></i>
                <div>
                    <strong>@L["Rules_Consequence1Title"]</strong>
                    <p>@L["Rules_Consequence1Text"]</p>
                </div>
            </div>
            <div class="rules-consequence">
                <i class="bi bi-exclamation-circle" style="color:#e53935"></i>
                <div>
                    <strong>@L["Rules_Consequence2Title"]</strong>
                    <p>@L["Rules_Consequence2Text"]</p>
                </div>
            </div>
            <div class="rules-consequence">
                <i class="bi bi-slash-circle" style="color:#b71c1c"></i>
                <div>
                    <strong>@L["Rules_Consequence3Title"]</strong>
                    <p>@L["Rules_Consequence3Text"]</p>
                </div>
            </div>
        </div>
    </div>

    <div class="guide-note">
        <i class="bi bi-info-circle"></i>
        @L["Rules_AppealNote"]
    </div>
</div>
