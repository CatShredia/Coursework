@page "/forgot-password"
@using Microsoft.JSInterop
@layout AuthLayout
@inject IJSRuntime JS

<PageTitle>Восстановление пароля — Runews</PageTitle>

<div class="auth-card">
    <button class="auth-back" @onclick="GoBack">
        <i class="bi bi-arrow-left"></i> Назад
    </button>
    <div class="auth-logo">
        <span>Runews</span>
    </div>
    <h1 class="auth-title">Восстановление пароля</h1>
    <p class="auth-subtitle">Введите email — мы отправим ссылку для сброса пароля.</p>

    @if (_sent)
    {
        <div class="auth-success">
            <i class="bi bi-check-circle"></i>
            Письмо отправлено на <strong>@_email</strong>. Проверьте почту.
        </div>
        <div class="auth-links" style="margin-top:16px">
            <a href="/login">Вернуться ко входу</a>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="auth-error">
                <i class="bi bi-exclamation-circle"></i> @_error
            </div>
        }

        <div class="auth-field">
            <label>Email</label>
            <div class="input-wrap">
                <i class="bi bi-envelope"></i>
                <input type="email" placeholder="you@example.com"
                       @bind="_email" @bind:event="oninput" />
            </div>
        </div>

        <button class="auth-btn" @onclick="Submit" disabled="@_loading">
            @if (_loading) { <span class="auth-spinner"></span> }
            else { <span>Отправить ссылку</span> }
        </button>
    }
</div>

@code {
    private string _email = "";
    private string? _error;
    private bool _loading, _sent;
    
    private void GoBack() => JS.InvokeVoidAsync("history.back");

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_email))
        { _error = "Введите email."; return; }

        _loading = true; _error = null;
        await Task.Delay(800); // заглушка до реализации API
        _sent = true;
        _loading = false;
    }
}
