@page "/forgot-password"
@using CatshrediasNews.Client.Models
@using Microsoft.JSInterop
@using System.Net.Http.Json
@layout AuthLayout
@inject IJSRuntime JS
@inject HttpClient Http
@inject CultureService Culture

<PageTitle>@L["Auth_ForgotTitle"] — Runews</PageTitle>

<div class="auth-card">
    <button class="auth-back" @onclick="GoBack">
        <i class="bi bi-arrow-left"></i> @L["Common_Back"]
    </button>
    <div class="auth-logo">
        <span>Runews</span>
    </div>
    <h1 class="auth-title">@L["Auth_ForgotTitle"]</h1>
    <p class="auth-subtitle">@L["Auth_ForgotSubtitle"]</p>

    @if (_sent)
    {
        <div class="auth-success">
            <i class="bi bi-envelope-check"></i>
            @string.Format(L["Auth_ForgotSuccess"], _email)
        </div>
        <div class="auth-links" style="margin-top:16px">
            <a href="/login">@L["Auth_BackToLogin"]</a>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="auth-error">
                <i class="bi bi-exclamation-circle"></i> @_error
            </div>
        }

        <div class="auth-field">
            <label>@L["Auth_Email"]</label>
            <div class="input-wrap @(_emailInvalid ? "input-invalid" : "")">
                <i class="bi bi-envelope"></i>
                <input type="email" placeholder="you@example.com"
                       @bind="_email" @bind:event="oninput"
                       @onblur="ValidateEmail" />
            </div>
            @if (_emailInvalid)
            {
                <span class="field-error">@L["Auth_ErrorEmail"]</span>
            }
        </div>

        <button class="auth-btn" @onclick="Submit" disabled="@_loading">
            @if (_loading) { <span class="auth-spinner"></span> }
            else { <span>@L["Auth_ForgotBtn"]</span> }
        </button>
    }
</div>

@code {
    private string _email = "";
    private string? _error;
    private bool _loading, _sent, _emailInvalid;

    private static readonly System.Text.RegularExpressions.Regex _emailRegex =
        new(@"^[^@\s]+@[^@\s]+\.[^@\s]+$", System.Text.RegularExpressions.RegexOptions.Compiled);

    private void GoBack() => JS.InvokeVoidAsync("history.back");

    private void ValidateEmail() =>
        _emailInvalid = !string.IsNullOrWhiteSpace(_email) && !_emailRegex.IsMatch(_email);

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_email))
        { _error = L["Auth_ForgotEnterEmail"]; return; }

        ValidateEmail();
        if (_emailInvalid) return;

        _loading = true; _error = null;

        var existsResp = await Http.PostAsJsonAsync("api/auth/check-email", _email);
        var exists     = existsResp.IsSuccessStatusCode &&
                         await existsResp.Content.ReadFromJsonAsync<bool>();
        if (!exists)
        {
            _error   = L["Auth_ForgotNotFound"];
            _loading = false;
            return;
        }

        await Http.PostAsJsonAsync("api/auth/forgot-password", new ForgotPasswordRequest
        {
            Email = _email,
            Culture = Culture.CurrentCulture
        });
        _sent    = true;
        _loading = false;
    }
}
