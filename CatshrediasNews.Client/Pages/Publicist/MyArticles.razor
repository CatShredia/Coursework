@page "/publicist/my-articles"
@inject AuthService Auth
@inject ArticleService ArticleSvc
@inject NavigationManager Nav

<PageTitle>Мои статьи — Runews</PageTitle>

@if (Auth.CurrentUser?.Role is not ("Publicist" or "Moderator" or "Admin"))
{
    Nav.NavigateTo("/");
    return;
}

<div class="admin-page">
    <div class="admin-header">
        <h1 class="page-title" style="margin:0">Мои статьи</h1>
        <a href="/publicist/create">
            <button class="auth-btn" style="width:auto;padding:8px 18px">
                <i class="bi bi-pencil-square"></i> Написать статью
            </button>
        </a>
    </div>

    <!-- Фильтр по статусу -->
    <div class="feed-tags">
        <button class="feed-tag-btn @(_statusFilter == "" ? "active" : "")"
                @onclick='() => _statusFilter = ""'>Все</button>
        @foreach (var s in _statuses)
        {
            var status = s;
            <button class="feed-tag-btn @(_statusFilter == status ? "active" : "")"
                    @onclick="() => _statusFilter = status">
                @StatusLabel(status)
            </button>
        }
    </div>

    @if (_loading)
    {
        <div class="admin-loading">
            <span class="auth-spinner" style="border-color:var(--border);border-top-color:var(--accent)"></span>
            Загрузка...
        </div>
    }
    else if (!_filtered.Any())
    {
        <div class="feed-empty">
            <i class="bi bi-file-earmark-text"></i>
            <p>Статей нет. <a href="/publicist/create" style="color:var(--accent)">Написать первую?</a></p>
        </div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Заголовок</th>
                        <th>Теги</th>
                        <th>Статус</th>
                        <th>Дата</th>
                        <th>Лайки</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var article in _filtered)
                    {
                        <tr>
                            <td>
                                <div style="font-weight:600;color:var(--text-primary);max-width:320px">
                                    @article.Title
                                </div>
                                <div style="font-size:12px;color:var(--text-muted);margin-top:2px;
                                            overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:320px">
                                    @article.Content
                                </div>
                            </td>
                            <td>
                                <div style="display:flex;gap:4px;flex-wrap:wrap">
                                    @foreach (var tag in article.Tags.Take(3))
                                    {
                                        <span class="article-tag">@tag</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <span class="status-badge @StatusClass(article.Status)">
                                    <i class="bi @StatusIcon(article.Status)"></i>
                                    @StatusLabel(article.Status)
                                </span>
                            </td>
                            <td style="white-space:nowrap;color:var(--text-muted);font-size:12px">
                                @article.PublishedAt.ToString("dd.MM.yyyy")
                            </td>
                            <td>
                                <span class="article-meta">
                                    <i class="bi bi-heart"></i> @article.LikesCount
                                </span>
                            </td>
                            <td>
                                <div class="action-btns">
                                    @if (!string.IsNullOrEmpty(article.SourceUrl))
                                    {
                                        <a href="@article.SourceUrl" target="_blank">
                                            <button class="action-btn" title="Открыть">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </button>
                                        </a>
                                    }
                                    <a href="/publicist/create?edit=@article.Id">
                                        <button class="action-btn action-btn-success" title="Редактировать">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </a>
                                    <button class="action-btn action-btn-danger"
                                            title="Удалить"
                                            @onclick="() => AskDelete(article)">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (_deleteTarget is not null)
{
    <div class="modal-overlay" @onclick="() => _deleteTarget = null">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-icon"><i class="bi bi-exclamation-triangle"></i></div>
            <h3 class="modal-title">Удалить статью?</h3>
            <p class="modal-text">
                «@_deleteTarget.Title» будет удалена безвозвратно.
            </p>
            <div class="modal-actions">
                <button class="modal-btn-cancel" @onclick="() => _deleteTarget = null">Отмена</button>
                <button class="modal-btn-confirm" @onclick="ConfirmDelete" disabled="@_deleteLoading">
                    @if (_deleteLoading) { <span class="auth-spinner"></span> }
                    else { <span>Удалить</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<ArticleDto> _articles = [];
    private string _statusFilter = "";
    private bool _loading = true, _deleteLoading;
    private ArticleDto? _deleteTarget;

    private static readonly string[] _statuses = ["Draft", "PendingReview", "Published", "Rejected"];

    private List<ArticleDto> _filtered => string.IsNullOrEmpty(_statusFilter)
        ? _articles
        : _articles.Where(a => a.Status == _statusFilter).ToList();

    protected override async Task OnInitializedAsync()
    {
        if (Auth.CurrentUser is null) return;
        _articles = await ArticleSvc.GetMyArticlesAsync();
        _loading  = false;
    }

    private void AskDelete(ArticleDto article) => _deleteTarget = article;

    private async Task ConfirmDelete()
    {
        if (_deleteTarget is null) return;
        _deleteLoading = true;
        var ok = await ArticleSvc.DeleteArticleAsync(_deleteTarget.Id);
        if (ok) _articles.Remove(_deleteTarget);
        _deleteTarget  = null;
        _deleteLoading = false;
    }

    private static string StatusLabel(string s) => s switch
    {
        "Draft"         => "Черновик",
        "PendingReview" => "На проверке",
        "Published"     => "Опубликована",
        "Rejected"      => "Отклонена",
        _               => s
    };

    private static string StatusClass(string s) => s switch
    {
        "Published"     => "status-active",
        "Rejected"      => "status-blocked",
        "PendingReview" => "status-pending",
        _               => ""
    };

    private static string StatusIcon(string s) => s switch
    {
        "Published"     => "bi-check-circle",
        "Rejected"      => "bi-x-circle",
        "PendingReview" => "bi-hourglass-split",
        _               => "bi-file-earmark"
    };
}
