@page "/publicist/create"
@page "/publicist/create/{EditId:int}"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject AuthService Auth
@inject ArticleService ArticleSvc
@inject GigaChadService GigaSvc
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(EditId.HasValue ? "Редактировать статью" : "Написать статью") — Runews</PageTitle>

@if (Auth.CurrentUser?.Role is not ("Publicist" or "Moderator" or "Admin"))
{
    Nav.NavigateTo("/");
    return;
}

<div class="editor-page">

    <!-- Заголовок -->
    <div class="editor-header">
        <h1 class="page-title" style="margin:0">
            @(EditId.HasValue ? "Редактировать статью" : "Написать статью")
        </h1>
        <div class="editor-header-actions">
            <button class="feed-sort-btn @(_preview ? "active" : "")"
                    @onclick="() => _preview = !_preview">
                <i class="bi bi-eye"></i> @(_preview ? "Редактор" : "Предпросмотр")
            </button>
            <button class="feed-sort-btn" @onclick="SaveDbDraft" disabled="@_savingDraft">
                @if (_savingDraft) { <span class="auth-spinner" style="width:14px;height:14px;border-color:var(--border);border-top-color:var(--accent)"></span> }
                else { <i class="bi bi-floppy2"></i> }
                Черновик
            </button>
            <button class="auth-btn" style="width:auto;padding:8px 20px"
                    @onclick="Save" disabled="@_saving">
                @if (_saving) { <span class="auth-spinner"></span> }
                else { <i class="bi bi-floppy"></i> }
                Сохранить
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="auth-error"><i class="bi bi-exclamation-circle"></i> @_error</div>
    }
    @if (!string.IsNullOrEmpty(_success))
    {
        <div class="auth-success"><i class="bi bi-check-circle"></i> @_success</div>
    }
    @if (_draftRestored)
    {
        <div class="auth-success" style="background:#fff8e1;border-color:#ffe082;color:#795548">
            <i class="bi bi-clock-history"></i> Черновик восстановлен.
            <button style="margin-left:auto;background:none;border:none;cursor:pointer;color:#795548;font-size:13px;font-weight:600"
                    @onclick="DiscardDraft">Отменить</button>
        </div>
    }

    <!-- Обложка -->
    <div class="editor-cover-row">
        <div class="auth-field" style="flex:1">
            <label>Обложка (ссылка)</label>
            <div class="input-wrap">
                <i class="bi bi-link-45deg"></i>
                <input type="url" placeholder="https://example.com/image.jpg"
                       @bind="_coverUrl" @bind:event="oninput" />
            </div>
        </div>
        <div style="display:flex;align-items:flex-end;gap:8px">
            <span style="color:var(--text-muted);font-size:13px;padding-bottom:10px">или</span>
            <label class="editor-upload-btn">
                @if (_coverUploading)
                {
                    <span class="auth-spinner" style="border-color:var(--border);border-top-color:var(--accent)"></span>
                }
                else
                {
                    <i class="bi bi-upload"></i>
                    <span>Загрузить</span>
                }
                <InputFile style="display:none" accept="image/*" OnChange="OnCoverSelected" />
            </label>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(_coverUrl))
    {
        <div class="editor-cover-preview">
            <img src="@_coverUrl" alt="cover" />
            <button class="editor-cover-remove" @onclick="() => _coverUrl = null" title="Удалить">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }
    @if (!string.IsNullOrEmpty(_coverError))
    {
        <span class="field-error">@_coverError</span>
    }

    <!-- Ссылки -->
    <a href="/editor-guide" class="editor-guide-link">
        <i class="bi bi-question-circle"></i> Инструкция к редактору
    </a>
    <a href="/publishing-rules" class="editor-guide-link">
        <i class="bi bi-shield-check"></i> Правила публикации
    </a>

    <!-- Заголовок статьи -->
    <input class="editor-title-input"
           type="text"
           placeholder="Заголовок статьи..."
           value="@_title"
           @oninput="OnTitleInput" />

    <!-- Теги -->
    @if (_tags.Any())
    {
        <div class="editor-tags-row">
            <span style="font-size:13px;color:var(--text-muted);white-space:nowrap">Теги:</span>
            @foreach (var tag in _tags)
            {
                <button class="feed-tag-btn @(_selectedTags.Contains(tag.Id) ? "active" : "")"
                        @onclick="() => ToggleTag(tag.Id)">
                    @tag.Name
                </button>
            }
        </div>

        <div class="editor-tags-row" style="margin-top:8px;align-items:flex-start">
            <span style="font-size:13px;color:var(--text-muted);white-space:nowrap;padding-top:10px">Поиск:</span>
            <div style="display:flex;flex-direction:column;gap:8px;flex:1">
                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                    <input class="admin-inline-input"
                           style="min-width:260px"
                           placeholder="Введите тег для поиска или создания"
                           @bind="_tagQuery"
                           @bind:event="oninput" />
                    <button class="feed-sort-btn"
                            disabled="@(!CanCreateTag)"
                            @onclick="CreateTagFromQuery">
                        <i class="bi bi-plus-lg"></i> Создать тег
                    </button>
                </div>
                @if (_tagSuggestions.Any())
                {
                    <div style="display:flex;gap:8px;flex-wrap:wrap">
                        @foreach (var tag in _tagSuggestions)
                        {
                            <button class="feed-tag-btn" @onclick="() => AddTag(tag.Id)">
                                @tag.Name
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (!_preview)
    {
        <!-- Панель инструментов -->
        <div class="editor-toolbar">
            <button class="editor-tool" title="Жирный (Ctrl+B)"      @onclick='() => Wrap("**", "**", "жирный текст")'><i class="bi bi-type-bold"></i></button>
            <button class="editor-tool" title="Курсив (Ctrl+I)"      @onclick='() => Wrap("*", "*", "курсив")'><i class="bi bi-type-italic"></i></button>
            <button class="editor-tool" title="Зачёркнутый"          @onclick='() => Wrap("~~", "~~", "текст")'><i class="bi bi-type-strikethrough"></i></button>
            <div class="editor-tool-sep"></div>
            <button class="editor-tool" title="Заголовок H1"         @onclick='() => LinePrefix("# ")'><i class="bi bi-type-h1"></i></button>
            <button class="editor-tool" title="Заголовок H2"         @onclick='() => LinePrefix("## ")'><i class="bi bi-type-h2"></i></button>
            <button class="editor-tool" title="Заголовок H3"         @onclick='() => LinePrefix("### ")'><i class="bi bi-type-h3"></i></button>
            <div class="editor-tool-sep"></div>
            <button class="editor-tool" title="Цитата"               @onclick='() => LinePrefix("> ")'><i class="bi bi-blockquote-left"></i></button>
            <button class="editor-tool" title="Код"                  @onclick='() => Wrap("`", "`", "код")'><i class="bi bi-code"></i></button>
            <button class="editor-tool" title="Блок кода"            @onclick='() => Wrap("```\n", "\n```", "код")'><i class="bi bi-code-square"></i></button>
            <div class="editor-tool-sep"></div>
            <button class="editor-tool" title="Маркированный список" @onclick='() => LinePrefix("- ")'><i class="bi bi-list-ul"></i></button>
            <button class="editor-tool" title="Нумерованный список"  @onclick='() => LinePrefix("1. ")'><i class="bi bi-list-ol"></i></button>
            <div class="editor-tool-sep"></div>
            <button class="editor-tool" title="Гиперссылка"          @onclick="InsertLink"><i class="bi bi-link-45deg"></i></button>
            <label class="editor-tool" title="Вставить изображение" style="cursor:pointer">
                @if (_imageUploading)
                {
                    <span class="auth-spinner" style="width:14px;height:14px;border-color:var(--border);border-top-color:var(--accent)"></span>
                }
                else
                {
                    <i class="bi bi-image"></i>
                }
                <InputFile style="display:none" accept="image/*" OnChange="OnContentImageSelected" />
            </label>
            <div class="editor-tool-sep"></div>
            <button class="editor-tool" title="Горизонтальная линия" @onclick='() => Insert("\n---\n")'><i class="bi bi-dash-lg"></i></button>
        </div>

        <textarea id="md-editor"
                  class="editor-textarea"
                  placeholder="Начните писать статью в формате Markdown..."
                  value="@_content"
                  @oninput="OnContentInput"
                  @onkeydown="OnKeyDown"
                  rows="24"></textarea>
    }
    else
    {
        <div class="editor-preview">
            @if (string.IsNullOrWhiteSpace(_content))
            {
                <p style="color:var(--text-muted)">Нет содержимого для предпросмотра.</p>
            }
            else
            {
                @((MarkupString)RenderMarkdown(_content))
            }
        </div>
    }

    <!-- GigaChad AI -->
    <div class="gigachad-block">
        <button class="gigachad-toggle @(_gigaOpen ? "open" : "")" @onclick="ToggleGiga">
            @if (_gigaOpen)
            {
                <i class="bi bi-x-lg"></i>
                <span>Отмена</span>
            }
            else
            {
                <span>Работа с</span>
                <svg style="width: 75px" viewBox="0 0 105 43" fill="var(--accent-ultra)" aria-label="На главную" class="Icon__IconNonSquare-sc-2c7dee0f-1 bQCLaW DesktopSidebar-styled__StyledLogoV2-sc-26ad63ba-5 gIBhPL" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"><path fill="inherit" d="m37.874 40.22 2.16-3.16h1.186v4.697h-1.073v-3.233l-2.18 3.233H36.8V37.06h1.074zM44.18 40.22l2.16-3.16h1.187v4.697h-1.074v-3.233l-2.181 3.233h-1.167V37.06h1.073v3.16zM56.84 38.067h-2.148v3.69H53.62V37.06h4.292v4.697h-1.073v-3.69zM62.033 41.837a3.2 3.2 0 0 1-1.043-.161 2.3 2.3 0 0 1-.815-.473 2.1 2.1 0 0 1-.534-.766 2.6 2.6 0 0 1-.191-1.036q0-.544.188-.99a2.24 2.24 0 0 1 1.337-1.258 3 3 0 0 1 1.051-.174c.386 0 .721.053 1.036.161q.473.162.816.473.341.311.533.766.19.45.191 1.036 0 .543-.188.989a2.2 2.2 0 0 1-.526.761q-.34.316-.811.493a3 3 0 0 1-1.044.177zm-1.442-2.43q0 .297.09.552.09.254.271.45.181.195.45.308.27.114.631.114.328 0 .594-.105.266-.103.451-.289.188-.183.286-.446.097-.262.097-.583 0-.287-.09-.548a1.3 1.3 0 0 0-.271-.453 1.3 1.3 0 0 0-.45-.308 1.6 1.6 0 0 0-.631-.114q-.334 0-.6.105a1.3 1.3 0 0 0-.45.292 1.3 1.3 0 0 0-.282.45 1.6 1.6 0 0 0-.098.578zM70.393 38.53l-1.269 2.159h-.597L67.22 38.54v3.214h-1.074V37.06h1.382l1.322 2.26 1.307-2.26h1.308v4.696H70.39V38.53zM75.592 41.837a3.2 3.2 0 0 1-1.044-.161 2.3 2.3 0 0 1-.815-.473 2.1 2.1 0 0 1-.533-.766 2.6 2.6 0 0 1-.191-1.036q0-.544.187-.99.19-.447.527-.766.339-.32.811-.492a3 3 0 0 1 1.05-.174c.385 0 .722.053 1.037.161q.474.162.815.473.343.311.533.766.192.45.192 1.036 0 .543-.188.989a2.2 2.2 0 0 1-.526.761q-.338.316-.812.493a3 3 0 0 1-1.043.177zm-1.442-2.43q0 .297.09.552.09.254.271.45.18.195.45.308.27.114.63.114.33 0 .594-.105.265-.103.454-.289.188-.183.285-.446.098-.262.097-.583 0-.287-.09-.548a1.3 1.3 0 0 0-.27-.453 1.3 1.3 0 0 0-.45-.308 1.6 1.6 0 0 0-.632-.114q-.335 0-.6.105a1.3 1.3 0 0 0-.45.292 1.25 1.25 0 0 0-.282.45 1.6 1.6 0 0 0-.097.578zM83.14 40.75h1.295v-3.69h1.074v3.69h.4