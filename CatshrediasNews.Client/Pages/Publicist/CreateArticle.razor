 16.863c.114 0 .205.092.205.205v3.858a.205.205 0 0 1-.205.205h-6.044a.206.206 0 0 0-.205.206v8.95a.206.206 0 0 1-.206.206h-5.782a.206.206 0 0 1-.205-.205v-8.95a.206.206 0 0 0-.206-.207h-6.044a.205.205 0 0 1-.206-.205v-3.858c0-.114.093-.205.206-.205zM56.083 16.792c.14 0 .253.115.253.253l.001.003v13.19c0 .14-.114.253-.253.253h-5.612a.254.254 0 0 1-.253-.253v-4.023c0-.152-.13-.27-.281-.252-1.21.15-3.215.232-4.783.232-6.362 0-8.41-1.743-8.41-6.358v-2.79c0-.14.115-.253.254-.253h5.67c.14 0 .253.114.253.253v2.324c0 2.16.943 2.626 3.45 2.626.778 0 2.78-.059 3.619-.143a.253.253 0 0 0 .227-.254v-4.555c0-.14.114-.253.253-.253zM48.874 1.799c.114 0 .206.092.206.205v3.565a.207.207 0 0 1-.206.206h-5.75a.205.205 0 0 0-.205.206v9.244a.206.206 0 0 1-.205.206H36.95a.206.206 0 0 1-.206-.207V2.004c0-.114.093-.205.206-.205zM56.178 1.8c.114 0 .205.092.205.205v7.357c0 .189.232.277.358.138l6.888-7.633a.2.2 0 0 1 .152-.068h5.877c.114 0 .206.093.206.206v13.22a.207.207 0 0 1-.206.206h-5.763a.206.206 0 0 1-.205-.207v-7.34a.206.206 0 0 0-.358-.138l-6.888 7.617a.2.2 0 0 1-.152.068h-5.876a.207.207 0 0 1-.207-.207V2.004c0-.113.094-.205.207-.205zM83.486 1.799c.114 0 .205.092.205.205v3.565a.206.206 0 0 1-.205.206h-5.75a.206.206 0 0 0-.206.206v9.244a.206.206 0 0 1-.205.206h-5.763a.207.207 0 0 1-.206-.207V2.004c0-.114.093-.205.206-.205z"></path><path fill="inherit" fill-rule="evenodd" d="M95.65 1.796c.06 0 .118.034.145.086l7.187 13.32c.056.105-.024.229-.146.229H95.99a.17.17 0 0 1-.15-.092l-.82-1.703a.17.17 0 0 0-.15-.093h-7.449a.17.17 0 0 0-.151.093l-.8 1.702a.17.17 0 0 1-.152.093h-6.215c-.12 0-.2-.12-.148-.225l6.753-13.32a.17.17 0 0 1 .148-.09zM91.25 5.9c-.06-.121-.241-.121-.3 0l-1.754 3.665c-.05.103.03.22.15.22h3.54c.12 0 .2-.118.15-.221h.001z" clip-rule="evenodd"></path></svg>
            }
        </button>

        @if (_gigaOpen)
        {
            <div class="gigachad-actions">
                @if (_content.Length < 50)
                {
                    <p class="gigachad-hint"><i class="bi bi-info-circle"></i> Введите не менее 50 символов для использования ИИ</p>
                }
                else
                {
                    <div class="gigachad-group">
                        <span class="gigachad-group-label">Текст</span>
                        <button class="gigachad-btn" disabled="@_gigaBusy" @onclick='() => RunGiga("improve")'>
                            <i class="bi bi-stars"></i> Улучшить
                        </button>
                        <button class="gigachad-btn" disabled="@_gigaBusy" @onclick='() => RunGiga("expand")'>
                            <i class="bi bi-arrows-expand"></i> Увеличить текст
                        </button>
                        <button class="gigachad-btn" disabled="@_gigaBusy" @onclick='() => RunGiga("shorten")'>
                            <i class="bi bi-arrows-collapse"></i> Уменьшить текст
                        </button>
                    </div>
                    <div class="gigachad-group">
                        <span class="gigachad-group-label">Проверка</span>
                        <button class="gigachad-btn" disabled="@_gigaBusy" @onclick='() => RunGiga("spellcheck")'>
                            <i class="bi bi-spell-check"></i> Орфография
                        </button>
                        <button class="gigachad-btn" disabled="@_gigaBusy" @onclick='() => RunGiga("check-rules")'>
                            <i class="bi bi-shield-check"></i> Правила публикации
                        </button>
                    </div>
                }
            </div>

            @if (_gigaBusy)
            {
                <div class="gigachad-loading">
                    <span class="auth-spinner" style="border-color:rgba(168,85,247,.3);border-top-color:#a855f7;width:20px;height:20px"></span>
                    <span>GigaChad думает<span class="gigachad-loading-dots"></span></span>
                </div>
            }
            @if (!string.IsNullOrEmpty(_gigaError))
            {
                <div class="auth-error" style="margin-top:8px"><i class="bi bi-exclamation-circle"></i> @_gigaError</div>
            }
            @if (!string.IsNullOrEmpty(_gigaResult))
            {
                <div class="gigachad-result">
                    <div class="gigachad-result-header">
                        @if (_gigaAction == "check-rules")
                        {
                            <span><i class="bi bi-shield-check"></i> Результат проверки</span>
                        }
                        else
                        {
                            <span><i class="bi bi-stars"></i> Предложение GigaChad</span>
                        }
                        <button class="gigachad-result-close" @onclick="() => _gigaResult = null"><i class="bi bi-x"></i></button>
                    </div>
                    <div class="gigachad-result-body">
                        @((MarkupString)RenderMarkdown(_gigaResult))
                    </div>
                    @if (_gigaAction != "check-rules")
                    {
                        <button class="gigachad-apply-btn" @onclick="ApplyGigaResult">
                            <i class="bi bi-check2"></i> Внести изменения
                        </button>
                    }
                </div>
            }
        }
    </div>

</div>

@code {
    [Parameter] public int? EditId { get; set; }

    private string _title   = "";
    private string _content = "";
    private string? _coverUrl;
    private string? _coverError;
    private bool   _preview, _saving, _savingDraft, _coverUploading, _imageUploading;
    private string? _error, _success;
    private List<TagDto> _tags = [];
    private HashSet<int> _selectedTags = [];

    private bool    _gigaOpen;
    private bool    _gigaBusy;
    private string? _gigaResult;
    private string? _gigaError;
    private string? _gigaAction;
    private bool    _draftRestored;
    private string _tagQuery = "";

    private string DraftKey => $"draft_{EditId?.ToString() ?? "new"}";

    protected override async Task OnInitializedAsync()
    {
        _tags = await ArticleSvc.GetTagsAsync();
        if (EditId.HasValue)
        {
            var article = await ArticleSvc.GetByIdAsync(EditId.Value);
            if (article is not null)
            {
                _title    = article.Title;
                _content  = article.Content;
                _coverUrl = article.ImageUrl;
                _selectedTags = _tags
                    .Where(t => article.Tags.Contains(t.Name))
                    .Select(t => t.Id)
                    .ToHashSet();
            }
        }

        // Восстанавливаем черновик если есть
        var draftTitle   = await JS.InvokeAsync<string?>("localStorage.getItem", DraftKey + "_title");
        var draftContent = await JS.InvokeAsync<string?>("localStorage.getItem", DraftKey + "_content");
        if (!string.IsNullOrEmpty(draftTitle) || !string.IsNullOrEmpty(draftContent))
        {
            // Черновик актуален только если он отличается от текущего содержимого
            if (draftTitle != _title || draftContent != _content)
            {
                _title   = draftTitle   ?? _title;
                _content = draftContent ?? _content;
                _draftRestored = true;
            }
        }
    }

    private void ToggleTag(int id)
    {
        if (!_selectedTags.Remove(id)) _selectedTags.Add(id);
    }

    private List<TagDto> _tagSuggestions => string.IsNullOrWhiteSpace(_tagQuery)
        ? []
        : _tags
            .Where(t => !_selectedTags.Contains(t.Id)
                && t.Name.Contains(_tagQuery.Trim(), StringComparison.OrdinalIgnoreCase))
            .OrderBy(t => t.Name)
            .Take(12)
            .ToList();

    private bool CanCreateTag =>
        !string.IsNullOrWhiteSpace(_tagQuery)
        && !_tags.Any(t => string.Equals(t.Name, _tagQuery.Trim(), StringComparison.OrdinalIgnoreCase));

    private void AddTag(int tagId)
    {
        _selectedTags.Add(tagId);
        _tagQuery = "";
    }

    private async Task CreateTagFromQuery()
    {
        if (!CanCreateTag) return;
        var created = await ArticleSvc.CreateTagAsync(_tagQuery.Trim());
        if (created is null)
        {
            _error = "Не удалось создать тег.";
            return;
        }

        if (_tags.All(t => t.Id != created.Id))
            _tags.Add(created);

        _selectedTags.Add(created.Id);
        _tagQuery = "";
    }

    private async Task SaveDbDraft()
    {
        if (string.IsNullOrWhiteSpace(_title) && string.IsNullOrWhiteSpace(_content)) return;
        _savingDraft = true; _error = null;
        var (article, error) = await ArticleSvc.SaveDraftToDbAsync(EditId, _title.Trim(), _content, _selectedTags.ToList(), _coverUrl);
        _savingDraft = false;
        if (error is not null) { _error = error; return; }
        await DiscardDraft();
        _success = "Черновик сохранён.";
        if (!EditId.HasValue && article is not null)
            Nav.NavigateTo("/publicist/create/" + article.Id, replace: true);
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_title))   { _error = "Введите заголовок."; return; }
        if (string.IsNullOrWhiteSpace(_content)) { _error = "Статья не может быть пустой."; return; }

        _saving = true; _error = null; _success = null;
        var (article, error) = await ArticleSvc.SaveArticleAsync(EditId, _title.Trim(), _content, _selectedTags.ToList(), _coverUrl);
        _saving = false;

        if (error is not null) { _error = error; return; }

        await DiscardDraft();
        _success = EditId.HasValue ? "Статья обновлена и отправлена на модерацию." : "Статья создана и отправлена на модерацию.";
        if (!EditId.HasValue && article is not null)
            Nav.NavigateTo("/publicist/create/" + article.Id, replace: true);
    }

    private async Task SaveDraft()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", DraftKey + "_title",   _title);
        await JS.InvokeVoidAsync("localStorage.setItem", DraftKey + "_content", _content);
    }

    private async Task DiscardDraft()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", DraftKey + "_title");
        await JS.InvokeVoidAsync("localStorage.removeItem", DraftKey + "_content");
        _draftRestored = false;
    }

    private async Task OnTitleInput(ChangeEventArgs e)
    {
        _title = e.Value?.ToString() ?? "";
        await SaveDraft();
    }

    private async Task OnContentInput(ChangeEventArgs e)
    {
        _content = e.Value?.ToString() ?? "";
        await SaveDraft();
    }

    private void ToggleGiga()
    {
        _gigaOpen   = !_gigaOpen;
        _gigaResult = null;
        _gigaError  = null;
    }

    private async Task RunGiga(string action)
    {
        if (_content.Length < 50) return;
        _gigaBusy = true; _gigaError = null; _gigaResult = null; _gigaAction = action;

        var result = action switch
        {
            "improve"     => await GigaSvc.ImproveAsync(_content),
            "expand"      => await GigaSvc.ExpandAsync(_content),
            "shorten"     => await GigaSvc.ShortenAsync(_content),
            "spellcheck"  => await GigaSvc.SpellcheckAsync(_content),
            "check-rules" => await GigaSvc.CheckRulesAsync(_content),
            _             => null
        };

        _gigaBusy = false;

        if (result is null) { _gigaError = "ГигаЧат недоступен. Попробуйте позже."; return; }
        // Всегда показываем результат в отдельном блоке
        _gigaResult = result;
    }

    private void ApplyGigaResult()
    {
        if (_gigaResult is null) return;
        _content    = _gigaResult;
        _gigaResult = null;
    }

    private async Task OnContentImageSelected(InputFileChangeEventArgs e)
    {
        var f = e.File;
        if (f.Size > 10 * 1024 * 1024) { _error = "Файл не должен превышать 10 МБ."; return; }
        _imageUploading = true;
        using var ms = new System.IO.MemoryStream();
        await f.OpenReadStream(10 * 1024 * 1024).CopyToAsync(ms);
        var bytes   = new ByteArrayContent(ms.ToArray());
        bytes.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(f.ContentType);
        var form = new MultipartFormDataContent();
        form.Add(bytes, "upload", f.Name);
        var (url, err) = await ArticleSvc.UploadImageAsync(form);
        _imageUploading = false;
        if (err is not null) { _error = err; return; }
        var md = $"\n![{f.Name}]({url})\n";
        _content = await JS.InvokeAsync<string>("mdEditor.insert", "md-editor", md);
        await SaveDraft();
    }

    private async Task OnCoverSelected(InputFileChangeEventArgs e)
    {
        _coverError = null;
        var f = e.File;
        if (f.Size > 10 * 1024 * 1024) { _coverError = "Файл не должен превышать 10 МБ."; return; }
        _coverUploading = true;
        using var ms = new System.IO.MemoryStream();
        await f.OpenReadStream(10 * 1024 * 1024).CopyToAsync(ms);
        var content = new ByteArrayContent(ms.ToArray());
        content.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(f.ContentType);
        var form = new MultipartFormDataContent();
        form.Add(content, "upload", f.Name);
        var (url, err) = await ArticleSvc.UploadImageAsync(form);
        _coverUploading = false;
        if (err is not null) { _coverError = err; return; }
        _coverUrl = url;
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (!e.CtrlKey) return;
        switch (e.Key)
        {
            case "b": await Wrap("**", "**", "жирный текст"); break;
            case "i": await Wrap("*",  "*",  "курсив");       break;
            case "k": await InsertLink();                      break;
        }
    }

    private async Task Wrap(string before, string after, string placeholder) =>
        _content = await JS.InvokeAsync<string>("mdEditor.wrap", "md-editor", before, after, placeholder);

    private async Task LinePrefix(string prefix) =>
        _content = await JS.InvokeAsync<string>("mdEditor.linePrefix", "md-editor", prefix);

    private async Task Insert(string text) =>
        _content = await JS.InvokeAsync<string>("mdEditor.insert", "md-editor", text);

    private async Task InsertLink() =>
        _content = await JS.InvokeAsync<string>("mdEditor.wrap", "md-editor", "[", "](https://)", "текст ссылки");

    private async Task InsertImage() =>
        _content = await JS.InvokeAsync<string>("mdEditor.wrap", "md-editor", "![", "](https://)", "описание");

    private static string RenderMarkdown(string md)
    {
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^### (.+)$", "<h3>$1</h3>", System.Text.RegularExpressions.RegexOptions.Multiline);
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^## (.+)$",  "<h2>$1</h2>", System.Text.RegularExpressions.RegexOptions.Multiline);
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^# (.+)$",   "<h1>$1</h1>", System.Text.RegularExpressions.RegexOptions.Multiline);
        md = System.Text.RegularExpressions.Regex.Replace(md, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        md = System.Text.RegularExpressions.Regex.Replace(md, @"\*(.+?)\*",     "<em>$1</em>");
        md = System.Text.RegularExpressions.Regex.Replace(md, @"~~(.+?)~~",     "<del>$1</del>");
        md = System.Text.RegularExpressions.Regex.Replace(md, @"```[\s\S]+?```", m =>
            "<pre><code>" + m.Value.Trim('`').Trim() + "</code></pre>");
        md = System.Text.RegularExpressions.Regex.Replace(md, @"`(.+?)`", "<code>$1</code>");
        md = System.Text.RegularExpressions.Regex.Replace(md, @"!\[(.+?)\]\((.+?)\)", "<img src=\"$2\" alt=\"$1\" style=\"max-width:100%\">");
        md = System.Text.RegularExpressions.Regex.Replace(md, @"\[(.+?)\]\((.+?)\)",  "<a href=\"$2\" target=\"_blank\">$1</a>");
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^> (.+)$", "<blockquote>$1</blockquote>", System.Text.RegularExpressions.RegexOptions.Multiline);
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^- (.+)$",    "<li>$1</li>", System.Text.RegularExpressions.RegexOptions.Multiline);
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^\d+\. (.+)$","<li>$1</li>", System.Text.RegularExpressions.RegexOptions.Multiline);
        md = System.Text.RegularExpressions.Regex.Replace(md, @"^---$", "<hr>", System.Text.RegularExpressions.RegexOptions.Multiline);
        md = string.Join("\n", md.Split('\n').Select(l => l.StartsWith('<') ? l : $"<p>{l}</p>"));
        return md;
    }
}
