@page "/profile"
@using Microsoft.AspNetCore.Components.Forms
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>@L["Profile_PageTitle"]</PageTitle>

@if (!Auth.IsAuthenticated && !_deleting)
{
    Console.WriteLine($"[Profile] OnParametersSet: not authenticated, redirecting to /login");
    Nav.NavigateTo("/login");
    return;
}

@if (_deleting)
{
    return;
}

<div class="profile-wrap">
        <div class="profile-card">
            <div class="profile-avatar">
                @if (!string.IsNullOrEmpty(Auth.CurrentUser!.AvatarUrl))
                {
                    <img src="@Auth.CurrentUser.AvatarUrl" class="profile-avatar-img"
                         alt="avatar" style="cursor:zoom-in"
                         @onclick="() => _showAvatarPreview = true" />
                }
                else
                {
                    <i class="bi bi-person-circle" style="color:@Auth.CurrentUser!.AvatarColor;font-size:64px"></i>
                }
            </div>
            <div class="profile-info">
                <div class="profile-name">@Auth.CurrentUser!.Username</div>
                <div class="profile-email">@Auth.CurrentUser.Email</div>
                <span class="profile-role">@Auth.CurrentUser.Role</span>
                <div style="display:flex;align-items:center;gap:10px;margin-top:8px;flex-wrap:wrap">
                    <label class="profile-avatar-upload-btn">
                        <i class="bi bi-upload"></i> @L["Profile_UploadAvatar"]
                        <InputFile style="display:none" accept="image/*" OnChange="OnAvatarSelected" />
                    </label>
                    @if (!string.IsNullOrEmpty(Auth.CurrentUser.AvatarUrl))
                    {
                        <button class="profile-avatar-delete" @onclick="DeleteAvatar" disabled="@_avatarLoading">
                            @if (_avatarLoading) { <span class="auth-spinner" style="width:14px;height:14px"></span> }
                            else { <i class="bi bi-trash3"></i> }
                            @L["Profile_DeletePhoto"]
                        </button>
                    }
                </div>
                @if (!string.IsNullOrEmpty(_avatarError))
                {
                    <div class="auth-error" style="margin-top:8px;font-size:12px"><i class="bi bi-exclamation-circle"></i> @_avatarError</div>
                }
            </div>
        </div>

        <div class="profile-section">
            <h2 class="profile-section-title">@L["Profile_EditSection"]</h2>

            @if (!string.IsNullOrEmpty(_success))
            {
                <div class="auth-success"><i class="bi bi-check-circle"></i> @_success</div>
            }
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="auth-error"><i class="bi bi-exclamation-circle"></i> @_error</div>
            }

            <div class="auth-field">
                <label>@L["Auth_Username"]</label>
                <div class="input-wrap">
                    <i class="bi bi-person"></i>
                    <input type="text" placeholder="@L["Profile_NewUsernamePlaceholder"]"
                           @bind="_username" @bind:event="oninput" />
                </div>
            </div>

            <div class="auth-field">
                <label>@L["Auth_Email"]</label>
                <div class="input-wrap @(_emailInvalid ? "input-invalid" : "")">
                    <i class="bi bi-envelope"></i>
                    <input type="email" placeholder="you@example.com"
                           @bind="_email" @bind:event="oninput"
                           @onblur="ValidateEmail" />
                </div>
                @if (_emailInvalid)
                {
                    <span class="field-error">@L["Auth_ErrorEmail"]</span>
                }
            </div>

            <div class="auth-field">
                <label>@L["Profile_NewPassword"] <span style="color:var(--text-muted);font-weight:400">@L["Profile_PasswordOptionalHint"]</span></label>
                <div class="input-wrap @(_passwordInvalid ? "input-invalid" : "")">
                    <i class="bi bi-lock"></i>
                    <input type="@(_showPassword ? "text" : "password")"
                           placeholder="@L["Profile_NewPassword"]"
                           @bind="_password" @bind:event="oninput"
                           @onblur="ValidatePassword" />
                    <button class="input-eye" type="button" @onclick="() => _showPassword = !_showPassword">
                        <i class="bi @(_showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                    </button>
                </div>
                @if (_passwordInvalid)
                {
                    <span class="field-error">@L["Auth_ErrorPasswordMin6"]</span>
                }
            </div>

            <div class="auth-field">
                <label>@L["Profile_ConfirmPassword"]</label>
                <div class="input-wrap @(_confirmInvalid ? "input-invalid" : "")">
                    <i class="bi bi-lock-fill"></i>
                    <input type="@(_showPassword ? "text" : "password")"
                           placeholder="@L["Profile_RepeatPasswordPlaceholder"]"
                           @bind="_confirm" @bind:event="oninput"
                           @onblur="ValidateConfirm" />
                </div>
                @if (_confirmInvalid)
                {
                    <span class="field-error">
                        @(string.IsNullOrWhiteSpace(_confirm)
                            ? L["Profile_ConfirmRequired"]
                            : L["Auth_ErrorPasswordMismatch"])
                    </span>
                }
            </div>

            <div class="auth-field">
                <label>@L["Auth_AvatarColor"] <span style="color:var(--text-muted);font-weight:400">@L["Profile_AvatarColorNoPhoto"]</span></label>
                <div class="avatar-color-row">
                    @foreach (var color in _palette)
                    {
                        <button type="button"
                                class="avatar-color-swatch @(_avatarColor == color ? "selected" : "")"
                                style="background:@color"
                                @onclick="() => _avatarColor = color">
                            @if (_avatarColor == color) { <i class="bi bi-check-lg"></i> }
                        </button>
                    }
                </div>
            </div>

            <div class="profile-actions">
                <button class="auth-btn" style="max-width:200px" @onclick="Save" disabled="@_loading">
                    @if (_loading) { <span class="auth-spinner"></span> }
                    else { <span>@L["Common_Save"]</span> }
                </button>
                <button class="auth-btn auth-btn-danger" style="max-width:200px" @onclick="Logout">
                    <i class="bi bi-box-arrow-right"></i> @L["Profile_Logout"]
                </button>
                <button class="auth-btn auth-btn-delete" style="max-width:200px" @onclick="() => _showDeleteModal = true">
                    <i class="bi bi-trash3"></i> @L["Profile_DeleteAccount"]
                </button>
            </div>
        </div>
    </div>

@if (_showAvatarPreview && !string.IsNullOrEmpty(Auth.CurrentUser?.AvatarUrl))
{
    <div class="modal-overlay" @onclick="() => _showAvatarPreview = false">
        <img src="@Auth.CurrentUser!.AvatarUrl" style="max-width:90vw;max-height:90vh;border-radius:12px;box-shadow:0 8px 40px rgba(0,0,0,.5)" @onclick:stopPropagation="true" />
    </div>
}

@if (_showDeleteModal)
{
    <div class="modal-overlay" @onclick="() => _showDeleteModal = false">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-icon">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <h3 class="modal-title">@L["Profile_DeleteTitle"]</h3>
            <p class="modal-text">@L["Profile_DeleteBody"]</p>
            @if (!string.IsNullOrEmpty(_deleteError))
            {
                <div class="auth-error" style="margin-bottom:12px">
                    <i class="bi bi-exclamation-circle"></i> @_deleteError
                </div>
            }
            <div class="modal-actions">
                <button class="modal-btn-cancel" @onclick="() => _showDeleteModal = false">
                    @L["Common_Cancel"]
                </button>
                <button class="modal-btn-confirm" @onclick="DeleteAccount" disabled="@_deleteLoading">
                    @if (_deleteLoading) { <span class="auth-spinner"></span> }
                    else { <span>@L["Profile_DeleteConfirm"]</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private string _username = "";
    private string _email = "";
    private string _password = "";
    private string _confirm = "";
    private string _avatarColor = "#1a73e8";
    private string? _error, _success, _deleteError, _avatarError;
    private bool _loading, _showPassword, _showDeleteModal, _deleteLoading, _deleting, _avatarLoading, _showAvatarPreview;
    private bool _emailInvalid, _passwordInvalid, _confirmInvalid;

    private static readonly string[] _palette =
    [
        "#1a73e8", "#e53935", "#43a047", "#fb8c00",
        "#8e24aa", "#00897b", "#f06292", "#546e7a"
    ];

    protected override void OnInitialized()
    {
        if (Auth.CurrentUser is not null)
        {
            _username    = Auth.CurrentUser.Username;
            _email       = Auth.CurrentUser.Email;
            _avatarColor = Auth.CurrentUser.AvatarColor;
        }
    }

    private void ValidateEmail()
    {
        _emailInvalid = !string.IsNullOrWhiteSpace(_email) &&
                        !System.Text.RegularExpressions.Regex.IsMatch(_email,
                            @"^[^@\s]+@[^@\s]+\.[^@\s]+$");
    }

    private void ValidatePassword()
    {
        _passwordInvalid = !string.IsNullOrWhiteSpace(_password) && _password.Length < 6;
    }

    private void ValidateConfirm()
    {
        _confirmInvalid = !string.IsNullOrWhiteSpace(_password) &&
                          _confirm != _password;
    }

    private async Task Save()
    {
        ValidateEmail();
        ValidatePassword();
        ValidateConfirm();
        if (_emailInvalid || _passwordInvalid || _confirmInvalid) return;

        _loading = true; _error = null; _success = null;

        var username = string.IsNullOrWhiteSpace(_username) ? null : _username;
        var email    = string.IsNullOrWhiteSpace(_email)    ? null : _email;
        var password = string.IsNullOrWhiteSpace(_password) ? null : _password;

        _error = await Auth.UpdateProfileAsync(username, email, password, _avatarColor);
        if (_error is null)
        {
            _success = L["Profile_SavedSuccess"];
            _password = "";
            _confirm = "";
        }
        _loading = false;
    }

    private async Task DeleteAccount()
    {
        _deleteLoading = true; _deleteError = null; _deleting = true;
        Console.WriteLine("[Profile] DeleteAccount: start");
        _deleteError = await Auth.DeleteAccountAsync();
        Console.WriteLine($"[Profile] DeleteAccount: error={_deleteError}, IsAuthenticated={Auth.IsAuthenticated}");
        _deleteLoading = false;
        if (_deleteError is null)
        {
            _showDeleteModal = false;
            Console.WriteLine("[Profile] Navigating to /?deleted=1");
            Nav.NavigateTo("/?deleted=1");
            Console.WriteLine("[Profile] NavigateTo called");
        }
        else
        {
            _deleting = false;
        }
    }

    private async Task OnAvatarSelected(InputFileChangeEventArgs e)
    {
        _avatarError = null;
        var f = e.File;
        if (f.Size > 5 * 1024 * 1024) { _avatarError = L["Profile_FileTooLarge"]; return; }
        _avatarLoading = true;
        using var ms      = new System.IO.MemoryStream();
        await f.OpenReadStream(5 * 1024 * 1024).CopyToAsync(ms);
        var content       = new ByteArrayContent(ms.ToArray());
        content.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(f.ContentType);
        var form          = new MultipartFormDataContent();
        form.Add(content, "upload", f.Name);
        _avatarError   = await Auth.UploadAvatarAsync(form);
        _avatarLoading = false;
    }

    private async Task DeleteAvatar()
    {
        _avatarLoading = true;
        _avatarError   = await Auth.DeleteAvatarAsync();
        _avatarLoading = false;
    }

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/");
    }
}
