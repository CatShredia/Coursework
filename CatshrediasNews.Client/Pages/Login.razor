@page "/login"
@using Microsoft.JSInterop
@layout AuthLayout
@inject AuthService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>–í—Ö–æ–¥ ‚Äî Runews</PageTitle>

<div class="auth-card">
    <button class="auth-back" @onclick="GoBack">
        <i class="bi bi-arrow-left"></i> –ù–∞–∑–∞–¥
    </button>
    <div class="auth-logo">
        <span>Runews</span>
    </div>
    <h1 class="auth-title">–í—Ö–æ–¥ –≤ –∞–∫–∫–∞—É–Ω—Ç</h1>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="auth-error">
            <i class="bi bi-exclamation-circle"></i>
            @if (_error == "email_not_confirmed")
            {
                <span>–ü–æ–¥—Ç–≤–µ—Ä–¥–∏—Ç–µ email –ø–µ—Ä–µ–¥ –≤—Ö–æ–¥–æ–º. –ü—Ä–æ–≤–µ—Ä—å—Ç–µ –ø–æ—á—Ç—É.</span>
            }
            else
            {
                <span>@_error</span>
            }
        </div>
    }
    @if (_confirmed)
    {
        <div class="auth-success">
            <i class="bi bi-check-circle"></i> Email –ø–æ–¥—Ç–≤–µ—Ä–∂–¥—ë–Ω! –¢–µ–ø–µ—Ä—å –º–æ–∂–Ω–æ –≤–æ–π—Ç–∏.
        </div>
    }

    <div class="auth-field">
        <label>Email</label>
        <div class="input-wrap @(_emailInvalid ? "input-invalid" : "")">
            <i class="bi bi-envelope"></i>
            <input type="email" placeholder="you@example.com"
                   @bind="_email" @bind:event="oninput"
                   @onblur="ValidateEmail" />
        </div>
        @if (_emailInvalid)
        {
            <span class="field-error">–í–≤–µ–¥–∏—Ç–µ –∫–æ—Ä—Ä–µ–∫—Ç–Ω—ã–π email (–Ω–∞–ø—Ä–∏–º–µ—Ä: you@example.com)</span>
        }
    </div>

    <div class="auth-field">
        <label>–ü–∞—Ä–æ–ª—å</label>
        <div class="input-wrap @(_passwordInvalid ? "input-invalid" : "")">
            <i class="bi bi-lock"></i>
            <input type="@(_showPassword ? "text" : "password")"
                   placeholder="–í–≤–µ–¥–∏—Ç–µ –ø–∞—Ä–æ–ª—å"
                   @bind="_password" @bind:event="oninput"
                   @onblur="ValidatePassword" />
            <button class="input-eye" type="button" @onclick="TogglePassword">
                <i class="bi @(_showPassword ? "bi-eye-slash" : "bi-eye")"></i>
            </button>
        </div>
        @if (_passwordInvalid)
        {
            <span class="field-error">–ü–∞—Ä–æ–ª—å –Ω–µ –º–æ–∂–µ—Ç –±—ã—Ç—å –ø—É—Å—Ç—ã–º</span>
        }
    </div>

    <button class="auth-btn" @onclick="Submit" disabled="@_loading">
        @if (_loading)
        {
            <span class="auth-spinner"></span>
        }
        else
        {
            <span>–í–æ–π—Ç–∏</span>
        }
    </button>

    <div class="auth-links">
        <a href="/forgot-password">–ó–∞–±—ã–ª–∏ –ø–∞—Ä–æ–ª—å?</a>
        <a href="/register">–°–æ–∑–¥–∞—Ç—å –∞–∫–∫–∞—É–Ω—Ç</a>
    </div>
</div>

@code {
    private string _email = "";
    private string _password = "";
    private string? _error;
    private bool _loading;
    private bool _showPassword;
    private bool _emailInvalid;
    private bool _passwordInvalid;
    private bool _confirmed;

    protected override void OnInitialized()
    {
        var uri   = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _confirmed = query["confirmed"] == "true";
    }

    private void ValidateEmail()
    {
        _emailInvalid = !string.IsNullOrWhiteSpace(_email) &&
                        !System.Text.RegularExpressions.Regex.IsMatch(_email,
                            @"^[^@\s]+@[^@\s]+\.[^@\s]+$");
    }

    private void ValidatePassword()
    {
        _passwordInvalid = string.IsNullOrWhiteSpace(_password);
    }

    private void TogglePassword() => _showPassword = !_showPassword;

    private void GoBack() => JS.InvokeVoidAsync("history.back");

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "–ó–∞–ø–æ–ª–Ω–∏—Ç–µ –≤—Å–µ –ø–æ–ª—è.";
            return;
        }
        ValidateEmail();
        ValidatePassword();
        _loading = true;
        _error = null;
        if (_emailInvalid || _passwordInvalid) { _loading = false; return; }
        _error = await Auth.LoginAsync(new() { Email = _email, Password = _password });
        _loading = false;
        if (_error is null) Nav.NavigateTo("/");
    }
}
