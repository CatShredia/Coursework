@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@inject IWebAssemblyHostEnvironment HostEnv
@inject HttpClient Http

@if (_visible)
{
    <div class="dev-mode-banner" role="status">
        Включен режим разработчика на сервере
    </div>
}

@code {
    private bool _visible;

    protected override async Task OnInitializedAsync()
    {
        if (!HostEnv.IsDevelopment())
            return;

        try
        {
            var health = await Http.GetFromJsonAsync<HealthResponse>("health");
            _visible = string.Equals(health?.Environment, "Development", StringComparison.OrdinalIgnoreCase);
        }
        catch
        {
            _visible = true;
        }
    }

    private sealed record HealthResponse(string Status, DateTime Utc, string Environment);
}
