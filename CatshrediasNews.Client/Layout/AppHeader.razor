@inject AuthService Auth
@inject ArticleService ArticleSvc
@inject NavigationManager Nav
@inject ThemeService ThemeSvc
@implements IDisposable

<header class="app-header">
    <a href="/" class="header-logo">Runews</a>

    <div class="header-actions">
        <button class="btn-search-trigger" @onclick="OpenSearch" title="Поиск">
            <i class="bi bi-search"></i>
        </button>
        <button class="btn-search-trigger" @onclick="ThemeSvc.ToggleAsync"
                title="@(ThemeSvc.IsDark ? "Светлая тема" : "Тёмная тема")">
            <i class="bi @(ThemeSvc.IsDark ? "bi-sun" : "bi-moon")"></i>
        </button>

        @if (Auth.IsAuthenticated)
        {
            <a href="/profile" class="header-profile-btn" title="@Auth.CurrentUser!.Username">
                @if (!string.IsNullOrEmpty(Auth.CurrentUser.AvatarUrl))
                {
                    <img src="@Auth.CurrentUser.AvatarUrl" class="header-avatar-img" alt="avatar" />
                }
                else
                {
                    <i class="bi bi-person-circle" style="color:@Auth.CurrentUser.AvatarColor"></i>
                }
                <span class="header-profile-name">@Auth.CurrentUser.Username</span>
            </a>
        }
        else
        {
            <a href="/login">
                <button class="btn-header btn-header-filled">Войти</button>
            </a>
        }
    </div>
</header>

@if (_searchOpen)
{
    <div class="search-overlay" @onclick="CloseSearch">
        <div class="search-modal" @onclick:stopPropagation="true">
            <div class="search-modal-inner">
                <i class="bi bi-search search-modal-icon"></i>
                <input @ref="_searchInput"
                       type="text"
                       class="search-modal-input"
                       placeholder="Поиск новостей..."
                       value="@_searchQuery"
                       @oninput="OnInput"
                       @onkeydown="OnSearchKeyDown" />
                @if (_searching)
                {
                    <span class="auth-spinner" style="border-color:var(--border);border-top-color:var(--accent);flex-shrink:0"></span>
                }
                <button class="search-modal-close" @onclick="CloseSearch">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            @if (_results is not null)
            {
                @if (_results.Count == 0)
                {
                    <div class="search-hint">Ничего не найдено по запросу «@_searchQuery»</div>
                }
                else
                {
                    <div class="search-results">
                        @foreach (var a in _results)
                        {
                            <a class="search-result-item" href="/articles/@a.Id" @onclick="CloseSearch">
                                @if (!string.IsNullOrEmpty(a.ImageUrl))
                                {
                                    <img src="@a.ImageUrl" class="search-result-img" alt="" />
                                }
                                <div class="search-result-body">
                                    <div class="search-result-title">@a.Title</div>
                                    <div class="search-result-meta">
                                        @a.PublishedAt.ToString("dd.MM.yyyy")
                                        @if (!string.IsNullOrEmpty(a.SourceName))
                                        {
                                            <span> · @a.SourceName</span>
                                        }
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                }
            }
            else if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                <div class="search-hint">Нажмите <kbd>Enter</kbd> для поиска по запросу «@_searchQuery»</div>
            }
            else
            {
                <div class="search-hint">Начните вводить запрос...</div>
            }
        </div>
    </div>
}

@code {
    private bool _searchOpen;
    private string _searchQuery = "";
    private ElementReference _searchInput;
    private List<ArticleDto>? _results;
    private bool _searching;
    private CancellationTokenSource? _cts;

    protected override void OnInitialized()
    {
        Auth.OnChange  += StateHasChanged;
        ThemeSvc.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Auth.OnChange     -= StateHasChanged;
        ThemeSvc.OnChange -= StateHasChanged;
        _cts?.Cancel();
    }

    private async Task OpenSearch()
    {
        _searchOpen = true;
        _results    = null;
        _searchQuery = "";
        await Task.Delay(50);
        await _searchInput.FocusAsync();
    }

    private void CloseSearch()
    {
        _searchOpen  = false;
        _searchQuery = "";
        _results     = null;
        _cts?.Cancel();
    }

    private async Task OnInput(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString() ?? "";
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _results = null;
            return;
        }

        // debounce 350ms
        try
        {
            await Task.Delay(350, token);
            _searching = true;
            StateHasChanged();
            _results   = await ArticleSvc.SearchAsync(_searchQuery);
            _searching = false;
        }
        catch (TaskCanceledException) { }
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") CloseSearch();
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_searchQuery))
        {
            _cts?.Cancel();
            _searching = true;
            StateHasChanged();
            _results   = await ArticleSvc.SearchAsync(_searchQuery);
            _searching = false;
        }
    }
}
