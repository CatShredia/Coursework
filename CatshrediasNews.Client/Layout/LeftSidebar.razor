@inject NavigationManager Nav
@inject AuthService Auth
@inject ModerationService ModerationSvc
@implements IDisposable

<nav class="app-sidebar-left">

    <div class="sidebar-section">
        <SidebarItem Href="/" Icon="bi-newspaper" Label="Лента" />
        <SidebarItem Href="/saved" Icon="bi-bookmark" Label="Избранное" />
    </div>

    @if (Auth.CurrentUser?.Role is "Publicist" or "Moderator" or "Admin")
    {
        <div class="sidebar-divider"></div>
        <div class="sidebar-section">
            <div class="sidebar-section-title">Публицистика</div>
            <SidebarItem Href="/publicist/create" Icon="bi-pencil-square" Label="Написать статью" />
            <SidebarItem Href="/publicist/my-articles" Icon="bi-file-earmark-text" Label="Мои статьи" />
        </div>
    }

    @if (Auth.CurrentUser?.Role is "Moderator" or "Admin")
    {
        <div class="sidebar-divider"></div>
        <div class="sidebar-section">
            <div class="sidebar-section-title">Модерация</div>
            <SidebarItem Href="/moderation/queue"   Icon="bi-list-check" Label="Очередь" Badge="@(_counts?.Queue   > 0 ? _counts.Queue.ToString()   : null)" />
            <SidebarItem Href="/moderation/reports" Icon="bi-flag"       Label="Жалобы"  Badge="@(_counts?.Reports > 0 ? _counts.Reports.ToString() : null)" />
        </div>
    }

    @if (Auth.CurrentUser?.Role == "Admin")
    {
        <div class="sidebar-divider"></div>
        <div class="sidebar-section">
            <div class="sidebar-section-title">Администрирование</div>
            <SidebarItem Href="/admin/rss" Icon="bi-rss" Label="Настройка RSS" />
            <SidebarItem Href="/admin/tags" Icon="bi-tags" Label="Управление тегами" />
            <SidebarItem Href="/admin/users" Icon="bi-people" Label="Пользователи" />
        </div>
    }

</nav>

@code {
    private ModerationCounts? _counts;

    protected override async Task OnInitializedAsync()
    {
        Auth.OnChange += OnAuthChange;
        ModerationSvc.CountsChanged += OnCountsChanged;
        await LoadCountsAsync();
    }

    private async void OnAuthChange()
    {
        await LoadCountsAsync();
        StateHasChanged();
    }

    private async void OnCountsChanged()
    {
        await LoadCountsAsync();
        StateHasChanged();
    }

    private async Task LoadCountsAsync()
    {
        if (Auth.CurrentUser?.Role is "Moderator" or "Admin")
            _counts = await ModerationSvc.GetCountsAsync();
        else
            _counts = null;
    }

    public void Dispose()
    {
        Auth.OnChange -= OnAuthChange;
        ModerationSvc.CountsChanged -= OnCountsChanged;
    }
}
