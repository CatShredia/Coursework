@inject NavigationManager Nav
@inject AuthService Auth
@inject ModerationService ModerationSvc
@implements IDisposable

<nav class="app-sidebar-left">

    <div class="sidebar-section">
        <SidebarItem Href="/" Icon="bi-newspaper" Label="@L["Nav_Feed"]" />
        <SidebarItem Href="/saved" Icon="bi-bookmark" Label="@L["Nav_Saved"]" />
    </div>

    @if (Auth.CurrentUser?.Role is "Publicist" or "Moderator" or "Admin")
    {
        <div class="sidebar-divider"></div>
        <div class="sidebar-section">
            <div class="sidebar-section-title">@L["Nav_SectionPublicist"]</div>
            <SidebarItem Href="/publicist/create" Icon="bi-pencil-square" Label="@L["Nav_WriteArticle"]" />
            <SidebarItem Href="/publicist/my-articles" Icon="bi-file-earmark-text" Label="@L["Nav_MyArticles"]" />
        </div>
    }

    @if (Auth.CurrentUser?.Role is "Moderator" or "Admin")
    {
        <div class="sidebar-divider"></div>
        <div class="sidebar-section">
            <div class="sidebar-section-title">@L["Nav_SectionModeration"]</div>
            <SidebarItem Href="/moderation/queue"   Icon="bi-list-check" Label="@L["Nav_Queue"]" Badge="@(_counts?.Queue   > 0 ? _counts.Queue.ToString()   : null)" />
            <SidebarItem Href="/moderation/reports" Icon="bi-flag"       Label="@L["Nav_Reports"]"  Badge="@(_counts?.Reports > 0 ? _counts.Reports.ToString() : null)" />
        </div>
    }

    @if (Auth.CurrentUser?.Role == "Admin")
    {
        <div class="sidebar-divider"></div>
        <div class="sidebar-section">
            <div class="sidebar-section-title">@L["Nav_SectionAdmin"]</div>
            <SidebarItem Href="/admin/rss" Icon="bi-rss" Label="@L["Nav_Rss"]" />
            <SidebarItem Href="/admin/tags" Icon="bi-tags" Label="@L["Nav_Tags"]" />
            <SidebarItem Href="/admin/users" Icon="bi-people" Label="@L["Nav_Users"]" />
        </div>
    }

</nav>

@code {
    private ModerationCounts? _counts;

    protected override async Task OnInitializedAsync()
    {
        Auth.OnChange += OnAuthChange;
        ModerationSvc.CountsChanged += OnCountsChanged;
        await LoadCountsAsync();
    }

    private async void OnAuthChange()
    {
        await LoadCountsAsync();
        StateHasChanged();
    }

    private async void OnCountsChanged()
    {
        await LoadCountsAsync();
        StateHasChanged();
    }

    private async Task LoadCountsAsync()
    {
        if (Auth.CurrentUser?.Role is "Moderator" or "Admin")
            _counts = await ModerationSvc.GetCountsAsync();
        else
            _counts = null;
    }

    public void Dispose()
    {
        Auth.OnChange -= OnAuthChange;
        ModerationSvc.CountsChanged -= OnCountsChanged;
    }
}
