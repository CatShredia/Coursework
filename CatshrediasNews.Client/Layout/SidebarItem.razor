@inject NavigationManager Nav

<a href="@Href" class="sidebar-item @(IsActive ? "active" : "")">
    <i class="bi @Icon item-icon"></i>
    <span>@Label</span>
    @if (!string.IsNullOrEmpty(Badge))
    {
        <span class="item-badge">@Badge</span>
    }
</a>

@code {
    [Parameter] public string Href { get; set; } = "/";
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string? Badge { get; set; }

    private bool IsActive => Href == "/"
        ? Nav.Uri.TrimEnd('/') == Nav.BaseUri.TrimEnd('/')
        : Nav.Uri.Contains(Href, StringComparison.OrdinalIgnoreCase);
}
