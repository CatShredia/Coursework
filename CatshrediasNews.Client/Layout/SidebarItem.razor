<NavLink href="@Href" class="sidebar-item" ActiveClass="active" Match="@GetMatch()">
    <i class="bi @Icon item-icon"></i>
    <span>@Label</span>
    @if (!string.IsNullOrEmpty(Badge))
    {
        <span class="item-badge">@Badge</span>
    }
</NavLink>

@code {
    [Parameter] public string Href { get; set; } = "/";
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string? Badge { get; set; }

    private NavLinkMatch GetMatch() => Href == "/" ? NavLinkMatch.All : NavLinkMatch.Prefix;
}
